{"id":271,"date":"2005-06-27T21:30:50","date_gmt":"2005-06-28T03:30:50","guid":{"rendered":"http:\/\/www.is-zen.org\/tc\/?p=271"},"modified":"2010-02-23T21:38:07","modified_gmt":"2010-02-24T03:38:07","slug":"lifeturn","status":"publish","type":"post","link":"http:\/\/www.is-zen.org\/tc\/2005\/lifeturn\/","title":{"rendered":"\u8d70\u8def\uff0c\u6211\u751f\u547d\u7684\u8f49\u6298\u9ede"},"content":{"rendered":"<p>\u4f5c\u8005\uff1a\u548c\u98a8<\/p>\n<p>\u5728\u9084\u6c92\u6709\u898b\u5230\u5e2b\u7236\u4e4b\u524d\uff0c\u5c31\u5df2\u7d93\u807d\u4eba\u8aaa\u8d77\u5e2b\u7236\u662f\u6559\u300c\u8d70\u8def\u300d\u7684\u3002\u800c\u76f8\u4fe1\u8a31\u591a\u4eba\u4e5f\u548c\u6211\u6709\u540c\u6a23\u7684\u53cd\u61c9\uff0c\u8d70\u8def\uff0c\u8ab0\u4e0d\u6703\u5462\uff1f\u70ba\u4ec0\u9ebc\u9084\u8981\u6559\u8d70\u8def\u5462\uff1f\u4f46\u5c31\u5728\u807d\u904e\u5e2b\u7236\u548c\u8001\u540c\u4fee\u5011\u7684\u89e3\u8aaa\u5f8c\uff0c\u62b1\u8457\u59d1\u4e14\u4e00\u8a66\u7684\u5fc3\u60c5\uff0c\u7576\u5929\u56de\u5bb6\u5f8c\u5c31\u958b\u59cb\u5728\u81ea\u5df1\u7684\u623f\u88e1\u8d70\u8def\u3002\u8d70\u8457\u8d70\u8457\uff0c\u7adf\u5ffd\u7136\u89ba\u5f97\u81ea\u5df1\u56de\u5230\u4e86\u4e94\u6b72\u6642\u7684\u4e00\u500b\u5c0f\u5973\u5b69\uff0c\u958b\u61f7\u5730\u5728\u4e00\u7247\u5927\u8349\u539f\u4e0a\u6f2b\u6b65\u5954\u8dd1\uff0c\u6211\u958b\u5fc3\u6975\u4e86\uff0c\u5c31\u5728\u623f\u88e1\uff0c\u6211\u5c31\u60f3\u8981\u8dd1\u8d77\u4f86\uff0c\u8df3\u8d77\u4f86\uff0c\u98db\u8d77\u4f86\u2026\u2026\u7b2c\u4e8c\u5929\u898b\u5230\u5e2b\u7236\uff0c\u5e2b\u7236\u8aaa\uff0c\u9019\u5c31\u662f\u300c\u548c\u81ea\u5df1\u5728\u4e00\u8d77\u300d\uff0c\u4f46\u662f\uff0c\u53ef\u4e0d\u80fd\u8ddf\u8457\u60c5\u7dd2\u8dd1\u8d77\u4f86\u8df3\u8d77\u4f86\uff0c\u9019\u5c31\u88ab\u5e36\u8d70\u4e86\uff0c\u9084\u662f\u8981\u56de\u5230\u8173\u5e95\uff0c\u7e7c\u7e8c\u89ba\u5bdf\u89c0\u7167\u3002\u800c\u6211\u4e5f\u624d\u4e4d\u7136\u9192\u609f\uff0c\u5118\u7ba1\u6578\u5341\u5e74\u4f86\u591a\u6b77\u4e16\u4e8b\uff0c\u7518\u82e6\u5099\u5690\uff0c\u5176\u5be6\uff0c\u5728\u81ea\u5df1\u5167\u5fc3\u7684\u6700\u6df1\u8655\uff0c\u4ecd\u7136\u9084\u662f\u90a3\u4e00\u500b\u4e94\u6b72\u7684\u5c0f\u5973\u5b69\uff0c\u55ae\u7d14\u7121\u67d3\uff0c\u96dc\u5ff5\u4e0d\u751f\u2026<\/p>\n<p>\u5f9e\u6b64\u4ee5\u5f8c\uff0c\u8d70\u8def\u6210\u4e86\u4f8b\u884c\u529f\u8ab2\uff0c\u800c\u5404\u7a2e\u5404\u6a23\u7684\u611f\u89ba\u5728\u6beb\u7121\u5fc3\u88e1\u6e96\u5099\u7684\u60c5\u6cc1\u4e0b\u4e0d\u6642\u731b\u7136\u5347\u8d77\u3002\u66fe\u7d93\uff0c\u8d70\u8457\u8d70\u8005\uff0c\u5ffd\u7136\u89ba\u5f97\uff0c\u5176\u5be6\u81ea\u5df1\u5df2\u7d93\u8d70\u8def\u8d70\u904e\u597d\u4e45\u597d\u4e45\u4e86\uff0c\u4e0d\u662f\u5e7e\u5929\u5e7e\u6708\u5e7e\u5e74\uff0c\u662f\u5df2\u7d93\u8d70\u904e\u5e7e\u767e\u5e74\u5e7e\u5343\u5e74\u4e86\u2026\u2026\u66fe\u7d93\uff0c\u8d70\u8457\u8d70\u8457\uff0c\u5ffd\u7136\u89ba\u5f97\uff0c\u751f\u547d\u7684\u5168\u90e8\uff0c\u8eab\u9ad4\u88e1\u6bcf\u4e00\u500b\u5206\u5b50\u7684\u5168\u90e8\uff0c\u5c31\u662f\u8d70\u8def\uff0c\u5225\u7121\u5176\u4ed6\uff0c\u4f60\u53ef\u4ee5\u9019\u6a23\u4e00\u76f4\u8d70\u4e0b\u53bb\uff0c\u5e7e\u767e\u5e74\u5e7e\u5343\u5e74\uff0c\u53ef\u4ee5\u4e00\u76f4\u9019\u6a23\u8d70\u4e0b\u53bb\u2026\u2026\u66fe\u7d93\uff0c\u8d70\u8457\u8d70\u8457\uff0c\u5ffd\u7136\u89ba\u5f97\uff0c\u4e0d\u8981\u4e86\uff0c\u4e0d\u8981\u4e86\uff0c\u4ec0\u9ebc\u90fd\u4e0d\u8981\u4e86\uff0c\u5c71\u6cb3\u5927\u5730\uff0c\u65e5\u6708\u661f\u8fb0\uff0c\u6240\u6709\u4eba\u4e16\u9593\u7684\u4e00\u5207\uff0c\u518d\u4e5f\u548c\u4f60\u4e00\u9ede\u95dc\u4fc2\u90fd\u6c92\u6709\u4e86\uff0c\u53ea\u6709\u8d70\u8def\uff0c\u53ea\u6709\u8d70\u8def\u2026\u2026<\/p>\n<p>\u8eab\u4e0a\u7684\u611f\u89ba\u66f4\u662f\u8b93\u4eba\u5fd9\u4e82\uff0c\u751a\u81f3\u8b93\u4eba\u9a5a\u5687\u3002\u5c31\u5728\u958b\u59cb\u8d70\u8def\u7684\u524d\u5e7e\u6b21\uff0c\u6709\u4e00\u56de\uff0c\u8d70\u8457\u8d70\u8457\uff0c\u5ffd\u7136\u5168\u8eab\u50cf\u6f38\u51cd\u4eba\u4e00\u6a23\uff0c\u5728\u5e7e\u79d2\u9418\u4e4b\u5167\uff0c\u6574\u500b\u8eab\u9ad4\u5c31\u51dd\u56fa\u6210\u50cf\u584a\u5927\u77f3\u982d\u4e00\u6a23\uff0c\u53ea\u597d\u8b39\u8a18\u5e2b\u7236\u6559\u5c0e\uff0c\u4e0d\u5e36\u610f\u5ff5\uff0c\u53ea\u662f\u770b\u8457\uff0c\u9010\u6f38\u9010\u6f38\u624d\u6062\u5fa9\u6b63\u5e38\u3002\u6709\u4e00\u56de\uff0c\u8d70\u8457\u8d70\u8457\uff0c\u8173\u6b65\u5b9b\u4f3c\u7d81\u4e0a\u4e86\u5927\u9435\u584a\uff0c\u6c88\u91cd\u5230\u5e7e\u4e4e\u7121\u6cd5\u8209\u6b65\uff0c\u9694\u5929\u96d9\u8173\u9178\u75db\u4e0d\u5df2\u3002\u6709\u4e00\u56de\uff0c\u7a81\u7136\u89ba\u5f97\u5468\u570d\u7684\u7a7a\u6c23\u90fd\u51dd\u7d50\u6210\u9eb5\u7cca\u72c0\uff0c\u6574\u500b\u4eba\u5c31\u50cf\u6389\u5728\u4e00\u5927\u7cf0\u829d\u9ebb\u7cca\u88e1\uff0c\u751a\u81f3\u9084\u805e\u5f97\u5230\u9999\u5674\u5674\u7684\u829d\u9ebb\u5473\u2026\u2026\u6709\u4e00\u5929\uff0c\u7d04\u508d\u665a\u6642\u5206\uff0c\u6211\u96d9\u624b\u7684\u624b\u638c\u5fc3\u958b\u59cb\u51fa\u73fe\u7d05\u75b9\uff0c\u7136\u5f8c\u9019\u4e9b\u7d05\u75b9\u5f9e\u624b\u638c\u6f2b\u958b\u5230\u624b\u81c2\u3001\u8eab\u9ad4\uff0c\u5f80\u4e0a\u5230\u6574\u500b\u982d\u81c9\uff0c\u5f80\u4e0b\u76f4\u5230\u96d9\u8173\u3001\u8173\u5e95\u3002\u5230\u591c\u534a\u6642\uff0c\u5168\u8eab\u4e0a\u4e0b\u7121\u4e00\u8655\u6c92\u6709\u75b9\u5b50\uff0c\u800c\u4e14\u7565\u5e36\u9ebb\u7662\u3002\u6211\u5fc3\u60f3\uff0c\u9019\u4e0b\u53ef\u7cdf\u4e86\uff0c\u5929\u4eae\u5f8c\u975e\u5f97\u53bb\u770b\u76ae\u819a\u79d1\u4e0d\u884c\u3002\u7d50\u679c\uff0c\u5c31\u50cf\u8d77\u75b9\u6642\u5982\u6d77\u6c34\u6f32\u6f6e\u822c\uff0c\u5f9e\u4e0b\u534a\u591c\u8d77\uff0c\u75b9\u5b50\u5c31\u50cf\u6d77\u6c34\u9000\u6f6e\u4e00\u6a23\u6f38\u6b21\u6d88\u6563\uff0c\u5230\u51cc\u6668\u5929\u660e\u6642\u5c31\u5df2\u5e7e\u4e4e\u5168\u6578\u6563\u53bb\u4e86\u3002\u9019\u4e9b\u90fd\u662f\u5728\u521d\u59cb\u8d70\u8def\u6642\u51fa\u73fe\u7684\u72c0\u614b\u3002<\/p>\n<p>\u96a8\u5f8c\u53c3\u52a0\u7b2c\u4e00\u6b21\u79aa\u4fee\u73ed\u3002\u6709\u4e00\u5929\u665a\u4e0a\u7761\u89ba\u6642\uff0c\u5ffd\u7136\u89ba\u5f97\u4e00\u80a1\u5f37\u5927\u7684\u6c23\u6d41\u5f9e\u8173\u5e95\u76f4\u885d\u4e0a\u8166\u90e8\uff0c\u6574\u500b\u982d\u6f32\u6210\u597d\u5e7e\u500d\u5927\uff0c\u6211\u53c8\u96e3\u53d7\uff0c\u53c8\u9a5a\u5687\uff0c\u5e7e\u4e4e\u8981\u558a\u6551\u547d\u4e86\u3002\u9019\u6642\uff0c\u5ffd\u7136\u6709\u4e00\u9053\u6e05\u6dbc\u5982\u5c71\u6cc9\u6c34\u822c\u7684\u6db2\u9ad4\u5f9e\u982d\u9802\u7051\u904d\u4e0b\u4f86\uff0c\u6574\u500b\u4eba\u5fb9\u5e95\u8eab\u5fc3\u8212\u66a2\u3002\u7b2c\u4e8c\u5929\uff0c\u96a8\u8457\u540c\u4fee\u5011\u5230\u516c\u5712\u8d70\u8def\u6642\uff0c\u5206\u5916\u89ba\u5f97\u8033\u8070\u76ee\u660e\u3002\u5712\u88e1\u7684\u6a39\u6728\uff0c\u8449\u8449\u770b\u5f97\u5206\u660e\uff1b\u540c\u4fee\u5011\u4e09\u4e09\u5169\u5169\u805a\u96c6\u7684\u8ac7\u8a71\uff0c\u6bcf\u4eba\u6bcf\u53e5\u7684\u4ea4\u8ac7\u90fd\u6e05\u695a\u807d\u5728\u8033\u88e1\u3002\u9019\u7a2e\u73fe\u8c61\u96a8\u5f8c\u5c31\u6162\u6162\u6d88\u9000\u4e86\u3002<\/p>\n<p>\u4ee5\u5f8c\u8d70\u8def\u6642\uff0c\u8eab\u4e0a\u6c23\u6a5f\u7684\u6d41\u52d5\u958b\u59cb\u6bd4\u8f03\u660e\u986f\u51fa\u73fe\u3002\u6211\u5f9e\u4f86\u6c92\u5b78\u904e\u6c23\u529f\uff0c\u4f46\u662f\u6bcf\u5929\u8d70\u8def\u90fd\u53ef\u4ee5\u89ba\u5bdf\u5230\u9ad4\u5167\u7684\u8b8a\u5316\u3002\u5f9e\u525b\u958b\u59cb\u6642\u624b\u6307\u7684\u767c\u6f32\uff0c\u5230\u6c23\u6a5f\u5728\u4e0b\u4e39\u7530\u3001\u5728\u8179\u8154\u3001\u80f8\u8154\u3001\u5589\u8154\u3001\u5728\u8033\u90e8\u3001\u5728\u8166\u90e8\uff0c\u6bcf\u4e00\u500b\u90e8\u4f4d\u7684\u6c23\u6a5f\u767c\u52d5\u90fd\u53ef\u4ee5\u660e\u986f\u89ba\u5bdf\u5230\u3002\u6709\u8da3\u7684\u662f\uff0c\u5169\u624b\u4e94\u6307\u5c16\u4e5f\u90fd\u660e\u986f\u89ba\u5f97\u5230\u6709\u4e00\u80a1\u6c23\u6d41\u5728\u6307\u5c16\u6d41\u52d5\uff0c\u56e0\u800c\u806f\u60f3\u5230\u91d1\u5eb8\u5c0f\u8aaa\u300c\u5929\u9f8d\u516b\u90e8\u300d\u88e1\u6240\u63cf\u8ff0\u7684\u300c\u516d\u8108\u795e\u528d\u300d\u679c\u771f\u6240\u8a00\u4e0d\u865b\u3002\u96e3\u602a\u5e2b\u7236\u66fe\u8aaa\uff0c\u91d1\u5eb8\u5c0f\u8aaa\u88e1\u5beb\u7684\u6b66\u529f\uff0c\u90fd\u662f\u771f\u7684\uff01\uff01<\/p>\n<p>\u548c\u5916\u754c\u7684\u9023\u7d50\u4e5f\u66f4\u5bc6\u5207\u3002\u98a8\u5728\u5439\uff0c\u82b1\u7dbb\u653e\uff0c\u611f\u53d7\u90fd\u6bd4\u4ee5\u524d\u66f4\u70ba\u7d30\u81a9\u6df1\u523b\u3002\u6709\u4e00\u6b21\uff0c\u642d\u4e58\u7684\u516c\u8eca\u5230\u4e86\u67d0\u4e00\u7ad9\uff0c\u7ad9\u724c\u908a\u6709\u56db\u4e94\u4eba\u5728\u7b49\u8eca\u3002\u6211\u5750\u5728\u8eca\u88e1\uff0c\u7a81\u7136\u89ba\u5f97\u4ed6\u5011\u5c31\u662f\u6211\uff0c\u6211\u5c31\u662f\u4ed6\u5011\u3002\u6211\u611f\u89ba\u5230\u4ed6\u5011\u5728\u7b49\u8eca\u7684\u7126\u6025\uff0c\u611f\u89ba\u5230\u8eca\u5b50\u9032\u7ad9\u6642\u4ed6\u5011\u7684\u9b06\u4e86\u4e00\u53e3\u6c23\u3002\u751a\u81f3\u6709\u4e00\u5929\uff0c\u8d70\u5728\u8def\u4e0a\uff0c\u770b\u5230\u4e86\u4e00\u96bb\u87d1\u8782\uff08\u5443\uff01\uff09\uff0c\u6211\u7adf\u4e5f\u89ba\u5f97\u6211\u5c31\u662f\u90a3\u96bb\u87d1\u8782\uff0c\u53ef\u4ee5\u611f\u53d7\u5230\u87d1\u8782\u8eab\u9ad4\u5728\u5730\u4e0a\u7684\u722c\u52d5\u3002\u8fa6\u516c\u5ba4\u540c\u4e8b\u5fc3\u88e1\u6709\u4e0d\u5e73\uff0c\u5411\u6211\u8a34\u82e6\uff0c\u6211\u611f\u89ba\u5230\u5979\u7684\u8166\u6ce2\u5c31\u76f4\u63a5\u885d\u5411\u6211\uff0c\u6211\u7684\u982d\u75db\u5f97\u8981\u7206\u70b8\u3002\u5357\u6d77\u6d69\u52ab\u6d88\u606f\u50b3\u4f86\uff0c\u5118\u7ba1\u975e\u89aa\u975e\u6545\uff0c\u4f46\u662f\u9023\u7e8c\u5169\u500b\u661f\u671f\uff0c\u5de8\u5927\u7684\u50b7\u75db\u4e5f\u50cf\u6d77\u562f\u822c\u5c07\u6211\u5b8c\u5168\u6df9\u6c92\uff0c\u6211\u50cf\u662f\u81ea\u5df1\u4e5f\u7d93\u6b77\u4e86\u90a3\u5834\u6d69\u52ab\uff0c\u5fc3\u75db\uff0c\u5fc3\uff08\u81df\uff09\u662f\u771f\u6b63\u7684\u5728\u75db\u2026\u2026\u76f4\u5230\u7d93\u904e\u5e2b\u7236\u7684\u958b\u793a\uff0c\u88ab\u5e36\u8d70\u7684\u60c5\u7dd2\u624d\u9010\u6f38\u5e73\u5fa9\uff0c\u4e5f\u5c0d\u771f\u6b63\u7684\u300c\u5e73\u7b49\u300d\u3001\u300c\u7121\u5206\u5225\u300d\u6709\u4e86\u591a\u4e00\u5c64\u7684\u9818\u6703\u3002<\/p>\n<p>\u5728\u8a8d\u8b58\u5e2b\u7236\u4e4b\u524d\uff0c\u6211\u5e7e\u4e4e\u6c92\u6709\u63a5\u89f8\u904e\u4f5b\u6559\uff08\u4f5b\u5b78\uff09\uff0c\u6211\u4e00\u76f4\u8a8d\u70ba\uff0c\u751f\u547d\u56fa\u7136\u6709\u751c\u6709\u82e6\uff0c\u7d42\u7a76\u662f\u4e00\u5834\u7f8e\u9e97\u7684\u9957\u5bb4\uff0c\u503c\u5f97\u4eab\u53d7\uff0c\u503c\u5f97\u9ad4\u9a57\u3002\u4f46\u662f\u7d93\u7531\u8d70\u8def\uff0c\u6709\u4e00\u5929\uff0c\u8d70\u8457\u8d70\u8457\uff0c\u6211\u624d\u7a81\u7136\u77ad\u89e3\u70ba\u4ec0\u9ebc\u91cb\u8fe6\u6469\u5c3c\u4f5b\u72e0\u5fc3\u62cb\u68c4\u7687\u4f4d\u5b50\u6c11\uff0c\u5b0c\u59bb\u65b0\u5152\uff0c\u7368\u81ea\u4f86\u5230\u6797\u4e2d\uff0c\u4e00\u610f\u4fee\u884c\u3002\u539f\u4f86\u751f\u8001\u75c5\u6b7b\u8f2a\u8ff4\u8f3e\u8f49\u7121\u6709\u4e86\u671f\uff0c\u552f\u6709\u627e\u51fa\u6700\u5fb9\u5e95\u7684\u89e3\u812b\u4e4b\u9053\u2026\u2026\u3002\u6709\u5e7e\u6b21\uff0c\u8d70\u8457\u8d70\u8457\uff0c\u50cf\u662f\u8207\u4f5b\u540c\u884c\uff0c\u7121\u9650\u611f\u6fc0\u2026\u2026\u53e6\u5916\u6709\u4e00\u5929\uff0c\u4e5f\u662f\u8d70\u8457\u8d70\u8457\uff0c\u6211\u4e5f\u624d\u5ffd\u7136\u9ad4\u609f\u70ba\u4ec0\u9ebc\u516d\u7956\u653e\u4e0b\u5e74\u9081\u773c\u778e\u7684\u5be1\u6bcd\uff0c\u8dcb\u5c71\u6d89\u6c34\uff0c\u4f86\u5230\u4e94\u7956\u9762\u524d\u8aaa\uff1a\u300c\u9060\u4f86\u79ae\u5e2b\uff0c\u60df\u6c42\u4f5c\u4f5b\uff0c\u4e0d\u6c42\u9918\u7269\u3002\u300d\u6b64\u751f\u5728\u4e16\uff0c\u9664\u4e86\u7a76\u7adf\u6210\u5c31\uff0c\u6c92\u6709\u5176\u4ed6\u4e8b\u60c5\u53ef\u4ee5\u6bd4\u64ec\u4e86\u3002\u4fee\u884c\uff0c\u662f\u9060\u6bd4\u751f\u547d\u9084\u8981\u91cd\u8981\u7684\u4e8b\u3002\u822c\u82e5\u89c0\u7167\uff0c\u662f\u6210\u5c31\u7121\u4e0a\u83e9\u63d0\u552f\u4e00\u7684\u8def\u3002<\/p>\n<p>\u904e\u53bb\uff0c\u6211\u5f9e\u4e0d\u66fe\u60f3\u904e\u300c\u4fee\u884c\u300d\u548c\u81ea\u5df1\u6709\u4ec0\u9ebc\u95dc\u4fc2\uff0c\u6211\u662f\u6210\u719f\u7406\u6027\u7684\u73fe\u4ee3\u5973\u6027\u3002\u4f46\u662f\uff0c\u7d93\u7531\u8d70\u8def\uff0c\u8b93\u6211\u771f\u5be6\u9ad4\u9a57\u81ea\u5df1\u5167\u5728\u7684\u4f5b\u6027\uff0c\u9ad4\u9a57\u5230\u524d\u6240\u672a\u6709\u7684\u5be7\u975c\u548c\u8ae7\u3002\u539f\u4f86\u300c\u5fc3\u3001\u4f5b\u3001\u773e\u751f\u300d\u4e09\u7121\u5dee\u5225\u3002\u6b64\u5fc3\u6e05\u6de8\u5373\u70ba\u4f5b\uff0c\u6b64\u5fc3\u5984\u5ff5\u7121\u908a\u5373\u70ba\u773e\u751f\u3002\u4f5b\u5728\u6bcf\u500b\u4eba\u7684\u5fc3\u4e2d\uff0c\u53ea\u662f\u6211\u5011\u907a\u5fd8\u4e86\u597d\u4e45\u800c\u5df2\u3002\u8d70\u8def\uff0c\u662f\u6211\u751f\u547d\u7684\u8f49\u6298\u9ede\uff0c\u800c\u4fee\u884c\uff0c\u662f\u4eca\u5f8c\u7684\u552f\u4e00\u3002<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u66fe\u7d93\uff0c\u8d70\u8457\u8d70\u8005\uff0c\u5ffd\u7136\u89ba\u5f97\uff0c\u5176\u5be6\u81ea\u5df1\u5df2\u7d93\u8d70\u8def\u8d70\u904e\u597d\u4e45\u597d\u4e45\u4e86\uff0c\u4e0d\u662f\u5e7e\u5929\u5e7e\u6708\u5e7e\u5e74\uff0c\u662f\u5df2\u7d93\u8d70\u904e\u5e7e\u767e\u5e74\u5e7e\u5343\u5e74\u4e86\u2026\u2026\u66fe\u7d93\uff0c\u8d70\u8457\u8d70\u8457\uff0c\u5ffd\u7136\u89ba\u5f97\uff0c\u751f\u547d\u7684\u5168\u90e8\uff0c\u8eab\u9ad4\u88e1\u6bcf\u4e00\u500b\u5206\u5b50\u7684\u5168\u90e8\uff0c\u5c31\u662f\u8d70\u8def\uff0c\u5225\u7121\u5176\u4ed6\u3002<\/p>\n","protected":false},"author":1,"featured_media":0,"comment_status":"closed","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ngg_post_thumbnail":0,"_links_to":"","_links_to_target":""},"categories":[15],"tags":[],"_links":{"self":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/271"}],"collection":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/comments?post=271"}],"version-history":[{"co