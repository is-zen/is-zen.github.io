{"id":278,"date":"2005-07-09T21:43:32","date_gmt":"2005-07-10T03:43:32","guid":{"rendered":"http:\/\/www.is-zen.org\/tc\/?p=278"},"modified":"2010-02-23T21:46:00","modified_gmt":"2010-02-24T03:46:00","slug":"knowme","status":"publish","type":"post","link":"http:\/\/www.is-zen.org\/tc\/2005\/knowme\/","title":{"rendered":"\u5f9e\u8d70\u8def\u5230\u4e86\u89e3\u81ea\u5df1"},"content":{"rendered":"<p>\u4f5c\u8005\uff1a\u60e0\u6240<\/p>\n<p>\u5f9e\u807d\u8001\u5e2b\u8aaa\u4eba\u751f\u9053\u7406\uff0c\u89e3\u8b80\u7d93\u66f8\uff0c\u8a13\u7df4\u89c0\u7167\uff0c\u5230\u8001\u8001\u5be6\u5be6\u8d70\u8def\u3002\u770b\u662f\u5e73\u51e1\uff0c\u7136\u800c\u5728\u5e73\u51e1\u7684\u8a13\u7df4\u7576\u4e2d\u7d42\u65bc\u8b93\u6211\u4e86\u89e3\u6211\u81ea\u5df1\u3002<\/p>\n<p>\u89c0\u7167-\u5c31\u662f\u65bc\u884c\u4f4f\u5750\u81e5\u7576\u4e2d\u77e5\u9053\u81ea\u5df1\u7684\u8209\u624b\u6295\u8db3\uff0c\u76ae\u819a\u51b7\u71b1\u75db\u7662\u3002\u7d93\u904e\u4e00\u6bb5\u6642\u9593\u7684\u8a13\u7df4\u5bdf\u89ba\u5230\u81ea\u5df1\u8aaa\u8a71\u6642\u624b\u8db3\u821e\u8e48\uff0c\u5167\u5fc3\u7684\u4e0d\u8010\u7169\uff0c\u81c9\u4e0a\u8868\u60c5\u7684\u5c55\u73fe\u3002\u51e1\u6b64\u7a2e\u7a2e\u90fd\u4ee5\u7121\u610f\u8b58\u7684\u8868\u73fe\u51fa\u4f86\uff0c\u800c\u4e0d\u81ea\u77e5\u3002\u6709\u6b21\u6709\u540c\u4e8b\u5c0d\u6211\u8a2d\u8a08\u7684\u96fb\u8166\u7a0b\u5f0f\u6709\u7591\u554f\u4f86\u554f\u6211\uff0c\u7576\u6211\u958b\u59cb\u548c\u4ed6\u8faf\u8ad6\u540c\u6642\u6211\u770b\u5230\u81ea\u5df1\u81c9\u90e8\u7684\u8868\u60c5\uff0c\u7576\u7136\u4e0d\u662f\u597d\u81c9\u8272\u3002\u8a0e\u8ad6\u7684\u7d50\u679c\u4ed6\u540c\u610f\u6211\u7684\u8a2d\u8a08\uff0c\u6211\u5f97\u610f\u7684\u9023\u8eab\u9ad4\u90fd\u767c\u51fa\u8072\u97f3(\u7576\u7136\u53ea\u6709\u81ea\u5df1\u807d\u5f97\u5230)\uff0c\u5b8c\u5f8c\u4ed6\u5c0d\u6211\u8aaa\uff0c\u56e0\u70ba\u4ed6\u9808\u8981\u641e\u61c2\uff0c\u5fc5\u9808\u63d0\u51fa\u7591\u554f\u3002\u6211\u5b8c\u5168\u4e86\u89e3\uff0c\u4e5f\u770b\u5230\u6211\u8b93\u4ed6\u4e0d\u81ea\u5728\u7684\u539f\u56e0\u3002\u5225\u8aaa\u4ed6\u4e0d\u9ad8\u8208\uff0c\u9023\u6211\u81ea\u5df1\u90fd\u4e0d\u80fd\u5fcd\u53d7\u81ea\u5df1\u7684\u5fb7\u6027\u3002\u5c31\u5728\u9019\u4e86\u89e3\u53ca\u770b\u5230\u81ea\u5df1\u7684\u904e\u7a0b\u7576\u4e2d\uff0c\u767c\u73fe\u81ea\u5df1\u5982\u4f55\u9020\u56e0\u679c\u3002<\/p>\n<p>\u4eba\u8207\u4eba\u6709\u8457\u5bc6\u5207\u7684\u95dc\u4fc2\u3002\u4eba\u8207\u5927\u81ea\u7136\u4e5f\u6709\u8457\u5947\u5999\u7684\u95dc\u4fc2\u3002\u6709\u5929\u5728\u8fa6\u516c\u5ba4\u88e1\u5c45\u7136\u611f\u89ba\u5230\u5730\u5438\u8457\u6211\uff0c\u6bcf\u4e00\u6b65\u8d70\u4f86\u90fd\u9700\u8981\u6162\u6162\u7684\u8d70\uff0c\u8209\u6b65\u9808\u8981\u7528\u4e9b\u529b\uff0c\u843d\u6b65\u50cf\u662f\u88ab\u5438\u56de\u53bb\u3002\u9019\u5927\u6982\u5c31\u662f\u5730\u5fc3\u5f15\u529b\u3002\u6211\u662f\u500b\u6025\u6027\u5b50\u7684\u4eba\uff0c\u8d70\u8def\u7279\u5feb\uff0c\u9019\u6642\u4e5f\u4e0d\u5f97\u4e0d\u6162\u4e0b\u4f86\u3002\u50cf\u4e00\u7a2e\u7121\u5f62\u7684\u529b\u91cf\u5728\u6539\u8b8a\u8457\u6211\u3002\u8d70\u8def\u5e36\u8457\u89ba\u77e5\u7684\u7576\u4e2d\uff0c\u611f\u89ba\u5230\u81ea\u5df1\u7684\u610f\u5ff5\u5728\u4e0d\u77e5\u4e0d\u89ba\u7576\u4e2d\u6e1b\u5c11\uff0c\u5fc3\u4e2d\u975e\u5e38\u7684\u7965\u548c\u3002\u66f4\u5947\u5999\u7684\u662f\u8eab\u9ad4\u7684\u75bc\u75db\u4e5f\u5728\u4e0d\u77e5\u4e0d\u89ba\u7576\u4e2d\u75ca\u7652\u3002\u5c0d\u81ea\u5df1\u7684\u8eab\u9ad4\u72c0\u6cc1\u6bd4\u8f03\u6e05\u695a\u5f8c\uff0c\u5f80\u5f80\u5728\u751f\u75c5\u524d\u5c31\u5df2\u7d93\u611f\u89ba\u4e0d\u8212\u670d\u7684\u524d\u5146\uff0c\u4f8b\u5982\u611f\u5192\u3002\u5c31\u8d95\u5feb\u53bb\u8d70\u8def\uff0c\u8b93\u8eab\u9ad4\u81ea\u5df1\u53bb\u75ca\u7652\u5b83\u3002<\/p>\n<p>\u5e38\u807d\u4eba\u8aaa\u8d70\u8def\u53ef\u4ee5\u8eab\u9ad4\u5065\u5eb7\uff0c\u7f8e\u5bb9\u3002\u5982\u679c\u6c92\u6709\u81ea\u5df1\u53bb\u9ad4\u6703\uff0c\u5c31\u5f88\u96e3\u4e86\u89e3\u3002\u597d\u5e7e\u6b21\u8d70\u904e\u8def\u5f8c\u611f\u89ba\u5230\u81c9\u4e0a\u7684\u76ae\u819a\u5728\u6536\u7e2e\uff0c\u5982\u8cbc\u4e86\u9762\u819c\u4e00\u6a23\u3002\u9019\u624d\u604d\u7136\u5927\u609f\u5b83\u4e4b\u6240\u4ee5\u6709\u7f8e\u5bb9\u7684\u529f\u6548\u3002\u6b63\u662f\u73fe\u4ee3\u4eba\u8b1b\u7a76\u7684\u6297\u8001\u5316\uff0c\u9632\u6b62\u808c\u819a\u9b06\u5f1b\u4e0b\u5782\u7684\u597d\u65b9\u6cd5\u3002<\/p>\n<p>\u5728\u9019\u8d70\u8def\u53ca\u4e86\u89e3\u81ea\u5df1\u7684\u904e\u7a0b\u7576\u4e2d\u5145\u6eff\u4e86\u6050\u61fc\u8207\u611f\u6fc0\u3002\u6050\u61fc\u7684\u662f\u6211\u4e0d\u77e5\u9053\u6211\u9084\u6703\u88ab\u982d\u8166\u727d\u8d70\u591a\u4e45\u8d70\u591a\u9060\u3002\u611f\u6fc0\u7684\u662f\uff0c\u6211\u958b\u59cb\u53ef\u4ee5\u89e3\u81ea\u5df1\u7684\u5bc6\u78bc\u4e86\u3002\u4e0d\u6b62\u4e00\u6b21\u6211\u8b66\u89ba\u5230\uff0c\u6211\u5c0f\u6642\u5019\u5c31\u662f\u5982\u6b64\uff0c\u5c45\u7136\u9577\u5927\u5f8c\u7d72\u6beb\u6c92\u6539\uff0c\u6211\u4e0d\u662f\u5df2\u7d93\u9577\u5927\u6210\u719f\u4e86\u55ce\ufe56\u600e\u9ebc\u7fd2\u6027\u6703\u5982\u6b64\u6839\u6df1\u8482\u56fa\u7684\u8ddf\u8457\u6211\u3002\u6211\u5e38\u89ba\u5f97\u7fd2\u6027\uff0c\u696d\u529b\u5c31\u5982\u540c\u5bc6\u78bc\u822c\u7684\u5370\u5728\u6211\u7684\u751f\u547d\u88e1\u3002\u552f\u6709\u6211\u77e5\u9053\u6211\u7684\u5bc6\u78bc\u5f8c\u624d\u80fd\u89e3\u958b\u5b83\u3002<\/p>\n<p>\u6211\u5982\u679c\u4e0d\u77e5\u9053\u6211\u5c0d\u60c5\u89aa\u7684\u4e0d\u6368\uff0c\u5982\u4f55\u8ac7\u653e\u4e0b\u3002<br \/>\n\u6211\u5982\u679c\u4e0d\u77e5\u9053\u6211\u5c0d\u5c0f\u4e8b\u7684\u65a4\u65a4\u8a08\u8f03\uff0c\u5c0d\u672a\u4f86\u7684\u5180\u671b\u53ca\u7c4c\u5283\uff0c\u5982\u4f55\u8ac7\u96a8\u9806\u3002<br \/>\n\u6211\u5982\u679c\u4e0d\u77e5\u9053\u6211\u5c0d\u4eba\u8655\u4e8b\u56e0\u4eba\u800c\u7570\uff0c\u5982\u4f55\u8ac7\u4e0d\u5340\u5225\u3002<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u5728\u9019\u8d70\u8def\u53ca\u4e86\u89e3\u81ea\u5df1\u7684\u904e\u7a0b\u7576\u4e2d\u5145\u6eff\u4e86\u6050\u61fc\u8207\u611f\u6fc0\u3002\u6050\u61fc\u7684\u662f\u6211\u4e0d\u77e5\u9053\u6211\u9084\u6703\u88ab\u982d\u8166\u727d\u8d70\u591a\u4e45\u8d70\u591a\u9060\u3002\u611f\u6fc0\u7684\u662f\uff0c\u6211\u958b\u59cb\u53ef\u4ee5\u89e3\u81ea\u5df1\u7684\u5bc6\u78bc\u4e86\u3002<\/p>\n","protected":false},"author":1,"featured_media":0,"comment_status":"closed","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ngg_post_thumbnail":0,"_links_to":"","_links_to_target":""},"categories":[15],"tags":[],"_links":{"self":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/278"}],"collection":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/comments?post=278"}],"version-history":[{"count":1,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/278\/revisions"}],"predecessor-version":[{"id":279,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/278\/revisions\/279"}],"wp:attachment":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/media?parent=278"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/categories?post=278"},{"taxonomy":"post_tag","embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/tags?post=278"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}