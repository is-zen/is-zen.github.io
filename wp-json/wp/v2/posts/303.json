{"id":303,"date":"2005-07-26T22:27:41","date_gmt":"2005-07-27T04:27:41","guid":{"rendered":"http:\/\/www.is-zen.org\/tc\/?p=303"},"modified":"2010-02-23T22:30:16","modified_gmt":"2010-02-24T04:30:16","slug":"balance","status":"publish","type":"post","link":"http:\/\/www.is-zen.org\/tc\/2005\/balance\/","title":{"rendered":"\u5b9a\u6167\u96d9\u4fee\u8ac7\u8d70\u8def"},"content":{"rendered":"<p>\u4f5c\u8005\uff1a\u6625\u82b1<\/p>\n<p>\u8d70\u8def\u5951\u5165\u884c\u8005\u5c4b\u3000\u6e05\u695a\u660e\u767d\u5999\u4f5c\u529b<br \/>\n\u5b9a\u6167\u7686\u7531\u6b64\u89ba\u8655\u3000\u7121\u6846\u8996\u91ce\u50f9\u7dad\u5be6<\/p>\n<p>\u6211\u7684\u751f\u547d\u5f62\u614b\u5f88\u67d4\u5f31\uff0c\u6c92\u6709\u672c\u4e8b\uff0c\u4efb\u4f55\u74b0\u5883\u90fd\u80fd\u96a8\u9047\u800c\u5b89\u3002\u5728\u6c92\u6709\u81ea\u89ba\u610f\u8b58\u7684\u7fd2\u6c23\u4e2d\uff0c\u65e5\u5fa9\u4e00\u65e5\u3002\u8868\u76f8\u7684\u5713\u878d\uff0c\u5728\u6240\u6709\u81ea\u4ee5\u70ba\u597d\u7684\u898f\u7bc4\u4e2d\uff0c\u904e\u8457\u8868\u88e1\u4e0d\u4e00\u7684\u751f\u6d3b\u3002\u5916\u8868\u7684\u67d4\u9806\u537b\u6d41\u9732\u597d\u5f37\uff0c\u597d\u52dd\u7684\u50b2\u6c23\u3002\u51b7\u773c\u770b\u4e8b\u5883\uff0c\u5728\u884c\u4e8b\u4ed8\u51fa\u4e2d\u5e36\u8457\u5f37\u70c8\u7684\u8981\u6c42\uff0c\u5167\u5916\u7684\u4e0d\u5e73\u8861\uff0c\u9020\u5c31\u6211\u8eab\u5fc3\u9748\u81f4\u547d\u7684\u75db\u3002<\/p>\n<p>\u6e05\u695a\u8d70\u8def\u8b93\u6211\u660e\u767d\uff0c\u6163\u6027\u50cf\u7121\u660e\u4e00\u822c\u3002\u5728\u6163\u6027\u4e2d\u4e00\u5207\u90fd\u4e0d\u81ea\u89ba\u3002\u81ea\u89ba\u5c31\u662f\u6e05\u695a\u3002\u6e05\u695a\u50cf\u5149\u660e\u4e00\u822c\u3002\u5728\u6e05\u695a\u4e2d\u89ba\u77e5\u751f\u547d\u7684\u5947\u5999\u3002\u6e05\u695a\u8d70\u8def\u8b93\u6211\u751f\u547d\u66f4\u6709\u6d3b\u529b\u3002\u90a3\u500b\u529b\u91cf\u4e0d\u6703\u6d88\u8017\u53cd\u5012\u66f4\u96c6\u4e2d\uff0c\u66f4\u6709\u6bc5\u529b\u53bb\u5b8c\u6210\u76ee\u6a19\u3002\u4f8b\u5982\u65e9\u4e0a\u8d77\u5e8a\u7e3d\u662f\u982d\u660f\u773c\u82b1\uff0c\u4f46\u53ea\u8981\u6211\u770b\u5411\u81ea\u5df1\uff0c\u6e05\u695a\u5c31\u50cf\u7121\u9650\u7684\u529b\u91cf\uff0c\u7acb\u523b\u7cbe\u795e\u6e05\u9192\u3002\u5728\u65e5\u5e38\u7684\u6bcf\u4e00\u500b\u6642\u523b\uff0c\u53ea\u8981\u6e05\u695a\u50cf\u5728\u8d70\u8def\u4e00\u6a23\u3002\u6e05\u695a\u8d8a\u9023\u7e8c\uff0c\u5de5\u4f5c\u8d8a\u4e0d\u7d2f\u3002\u5728\u60c5\u7dd2\u65b9\u9762\u4e5f\u4e00\u6a23\uff0c\u8d8a\u6e05\u695a\uff0c\u60c5\u7dd2\u5c31\u8d8a\u7a69\u5b9a\u3002\u7a69\u5b9a\u4e2d\u53ef\u611f\u53d7\u8eab\u9ad4\u7684\u983b\u7387\u3002\u6bcf\u500b\u6bdb\u7d30\u5b54\u90fd\u53ef\u662f\u4e00\u500b\u500b\u7a7f\u900f\u7684\u901a\u8def\u3002\u6bcf\u500b\u7d30\u80de\u90fd\u4e0d\u5b89\u5b9a\u7684\u5728\u8df3\u8e8d\uff0c\u5728\u65cb\u8f49\u3002\u5c0f\u8178\u7a7f\u904e\u5927\u8178\u7684\u8072\u97f3\u90fd\u50cf\u662f\u4e00\u500b\u8a0a\u606f\uff0c\u8b93\u6211\u4e86\u89e3\u751f\u547d\u7684\u8108\u52d5\uff0c\u9023\u7e6b\u8457\u6e05\u695a\u66f4\u53ef\u8d85\u8d8a\u6163\u6027\u982d\u8166\u7684\u601d\u7dad\u3002\u53ef\u7528\u5404\u500b\u89d2\u5ea6\u4f86\u770b\u5f85\u5c0d\u932f\u7684\u5fae\u5999\uff0c\u4e0d\u518d\u88ab\u6846\u6846\u675f\u7e1b\u8457\u3002<\/p>\n<p>\u6e05\u695a\u8d70\u8def\u5f8c\uff0c\u6f38\u6f38\u770b\u660e\u767d\u6240\u6709\u7684\u597d\uff0c\u90fd\u662f\u5728\u7121\u80fd\u7684\u5fc3\u614b\u4e2d\uff0c\u9059\u671b\u4e0d\u53ef\u80fd\u5be6\u73fe\u5305\u88dd\u4e0b\u507d\u88dd\u7684\u865b\u507d\u3002\u9019\u662f\u6211\u9078\u64c7\u751f\u547d\u6210\u9577\u7684\u578b\u614b\u5448\u73fe\u7684\u98a8\u683c\u3002\u6211\u6e05\u695a\u770b\u8457\u81ea\u5df1\u7684\u73fe\u72c0\u3002\u8a18\u5f97\u521d\u8b58\u5e2b\u7236\uff0c\u5e2b\u4e91\uff1a\u300c\u53cd\u89c0\u81ea\u7167\u7684\u79d8\u610f\u300d\uff0c\u6211\u6df1\u6df1\u89ba\u53d7\u9019\u7a2e\u983b\u7387\uff0c\u592a\u719f\u6089\u4e86\uff0c\u5f77\u5f7f\u524d\u4e16\u5df2\u4fee\u7fd2\u5343\u767e\u56de\u3002\u770b\u5411\u81ea\u5df1\uff0c\u5728\u7406\u8ad6\u4e2d\uff0c\u884c\u4e8b\u4e0a\uff0c\u89c0\u5ff5\u4e0a\uff0c\u6211\u90fd\u662f\u5411\u5916\u770b\uff0c\u4e0d\u66fe\u770b\u5411\u81ea\u5df1\u3002\u4f8b\u5982\uff1a\u5728\u6163\u6027\u4e2d\u8d70\u8def\uff0c\u6211\u6dda\u6d41\u4e0d\u505c\uff0c\u592a\u76f8\u61c9\u4e86\u3002\u6211\u5728\u7121\u660e\u4e2d\u751f\u6d3b\u56db\u5341\u5e7e\u5e74\uff0c\u5728\u6163\u6027\u4e2d\u6c89\u6dea\uff0c\u5728\u7121\u660e\u4e2d\u751f\u5b58\uff0c\u4e0d\u80fd\u7406\u89e3\u751f\u547d\u53ef\u8cb4\u7684\u610f\u7fa9\u3002\u5728\u7121\u660e\u4e2d\u5e2b\u5ea6\uff0c\u5728\u89ba\u53d7\u4e2d\u81ea\u5ea6\uff0c\u6211\u770b\u8457\u81ea\u5df1\u7684\u8d77\u5fc3\u52d5\u5ff5\uff0c\u5728\u8d70\u8def\u4e2d\u77e5\u9053\u884c\u9032\u9593\u5ff5\u982d\u9032\u9032\u51fa\u51fa\uff0c\u5728\u4e0d\u59a5\u5354\u4e2d\u770b\u5230\u81ea\u6211\u50b2\u6162\u7684\u767e\u614b\uff0c\u592a\u6709\u610f\u601d\u4e86\u3002\u4ee5\u524d\u76f2\u832b\u5fd9\u7684\u751f\u6d3b\uff0c\u958b\u59cb\u6e05\u695a\u660e\u767d\u5b89\u5b9a\u3002<\/p>\n<p>\u4e09\u5e74\u591a\u4e86\uff0c\u5f9e\u4e0d\u77e5\u9053\u6e05\u695a\u5230\u77e5\u9053\u6e05\u695a\u3002\u751f\u547d\u7684\u5947\u8e5f\uff0c\u6084\u6084\u958b\u5c55\u3002\u5f88\u591a\u6f5b\u5728\u7684\u73fe\u8c61\uff0c\u5f9e\u4e0d\u77e5\u9053\u5230\u7a81\u7136\u660e\u767d\uff0c\u90fd\u4e0d\u5728\u9810\u671f\u4e2d\uff0c\u8b93\u6211\u9ad4\u6703\u5230\u751f\u547d\u6f5b\u5728\u7684\u80fd\u529b\u3002\u4e00\u6b21\u53c8\u4e00\u6b21\u4e86\u77e5\u5b78\u7121\u6b62\u76e1\u7684\u5999\u55bb\uff0c\u552f\u6709\u81ea\u5df1\u53bb\u5be6\u8b49\uff0c\u53bb\u8d70\u8def\u3002\u9ad4\u6703\u5230\u7684\u9ede\u9ede\u6ef4\u6ef4\uff0c\u90fd\u6210\u70ba\u81ea\u5df1\u751f\u547d\u4e2d\u7684\u4e00\u90e8\u4efd\u3002\u6211\u8d70\u51fa\u4f86\u7684\u8def\uff0c\u6642\u523b\u806f\u7e6b\u6211\u524d\u9032\u7684\u52a9\u529b\uff0c\u5c07\u6e05\u695a\u5ef6\u7e8c\uff0c\u6211\u660e\u767d\u6210\u5f7f\u662f\u5fc5\u7136\u7684\u7d50\u679c\u3002<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u5728\u60c5\u7dd2\u65b9\u9762\u4e5f\u4e00\u6a23\uff0c\u8d8a\u6e05\u695a\uff0c\u60c5\u7dd2\u5c31\u8d8a\u7a69\u5b9a\u3002\u7a69\u5b9a\u4e2d\u53ef\u611f\u53d7\u8eab\u9ad4\u7684\u983b\u7387\u3002\u6bcf\u500b\u6bdb\u7d30\u5b54\u90fd\u53ef\u662f\u4e00\u500b\u500b\u7a7f\u900f\u7684\u901a\u8def\u3002\u6bcf\u500b\u7d30\u80de\u90fd\u4e0d\u5b89\u5b9a\u7684\u5728\u8df3\u8e8d\uff0c\u5728\u65cb\u8f49\u3002<\/p>\n","protected":false},"author":1,"featured_media":0,"comment_status":"closed","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ngg_post_thumbnail":0,"_links_to":"","_links_to_target":""},"categories":[15],"tags":[],"_links":{"self":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/303"}],"collection":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/comments?post=303"}],"version-history":[{"count":2,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/303\/revisions"}],"predecessor-version":[{"id":305,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/303\/revisions\/305"}],"wp:attachment":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/media?parent=303"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/categories?post=303"},{"taxonomy":"post_tag","embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/tags?post=303"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}