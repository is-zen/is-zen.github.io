{"id":407,"date":"2002-05-21T09:53:50","date_gmt":"2002-05-21T15:53:50","guid":{"rendered":"http:\/\/www.is-zen.org\/tc\/?p=407"},"modified":"2010-03-03T10:45:45","modified_gmt":"2010-03-03T16:45:45","slug":"vajra_observing","status":"publish","type":"post","link":"http:\/\/www.is-zen.org\/tc\/2002\/vajra_observing\/","title":{"rendered":"\u91d1\u525b\u89c0\u5bdf"},"content":{"rendered":"<h3><img loading=\"lazy\" class=\"alignleft size-medium wp-image-412\" title=\"\u53e4\u4ead\u8b80\u66f8\u6703\u6f14\u8b1b\" src=\"http:\/\/www.is-zen.org\/tc\/wp-content\/uploads\/2010\/03\/P5149284_480-300x225.jpg\" alt=\"\u53e4\u4ead\u8b80\u66f8\u6703\u6f14\u8b1b\" width=\"300\" height=\"225\" srcset=\"http:\/\/www.is-zen.org\/tc\/wp-content\/uploads\/2010\/03\/P5149284_480-300x225.jpg 300w, http:\/\/www.is-zen.org\/tc\/wp-content\/uploads\/2010\/03\/P5149284_480.jpg 480w\" sizes=\"(max-width: 300px) 100vw, 300px\" \/>\u6316\u4e0d\u76e1\u7684\u5bf6\u85cf<\/h3>\n<p>\u4eca\u5e74\u4e00\u6708\uff0c\u53e4\u4ead\u8b80\u66f8\u6703\u8209\u8fa6\u4ee5\u300c\u751f\u547d\u7684\u9053\u8def\u300d\u70ba\u984c\u4e4b\u5206\u4eab\u8207\u8a0e\u8ad6\u6d3b\u52d5\uff0c\u65b0\u5a5a\u4e0d\u4e45\u7684 Vivian \u8207 Monte \u5e36\u9818\u9019\u6b21\u6d3b\u52d5\uff0c\u4ed6\u5011\u5728\u5206\u4eab\u8207\u8a0e\u8ad6\u904e\u7a0b\u4e2d\uff0c\u983b\u983b\u63d0\u53ca\u5728\u7f8e\u570b\u7684\u6771\u5317\u8001\u5e2b\uff0c\u5982\u4f55\u8b93\u4ed6\u5011\u77ad\u89e3\u300c\u6211\u300d\u3001\u300c\u751f\u547d\u300d\u3001\u300c\u4fee\u884c\u300d\u7b49\u8af8\u591a\u8981\u7fa9\uff0c\u4e26\u6559\u5c0e\u4ed6\u5011\u5982\u5be6\u89c0\u7167\u3001\u5168\u7136\u63a5 \u53d7\u3001\u5e6b\u52a9\u4ed6\u5011\u91d0\u6e05\u8a31\u591a\u77db\u76fe\u3001\u5f15\u5c0e\u4ed6\u5011\u8d70\u4e0a\u6b63\u78ba\u7684\u9053\u8def\u3001\u5fb9\u5e95\u6539\u8b8a\u4e86\u4ed6\u5011\u7684\u751f\u6d3b\u614b\u5ea6\u8207\u65b9\u5f0f\u3002\u7576\u6642\uff0c\u53c3\u8207\u6d3b\u52d5\u8005\u5747\u5c0d\u6771\u5317\u8001\u5e2b\u662f\u4ec0\u9ebc\u6a23\u7684\u4eba\uff0c\u70ba\u4f55\u6703\u5c0d\u4eba\u9020\u6210\u9019\u9ebc\u5927 \u7684\u5f71\u97ff\uff0c\u611f\u5230\u5341\u5206\u597d\u5947\u3002Vivian \u8207 Monte \u5728\u6d3b\u52d5\u7d50\u675f\u524d\u9810\u544a\uff0c\u6771\u5317\u8001\u5e2b\u5c07\u65bc\u4e94\u6708\u4f86\u53f0\uff0c\u5927\u5bb6\u90fd\u597d\u8208\u596e\uff0c\u8868\u793a\u4e00\u5b9a\u4e0d\u80fd\u932f\u904e\u9019\u500b\u6a5f\u6703\u3002<\/p>\n<p>\u4e94\u6708\uff0c\u6771\u5317\u8001\u5e2b\u5982\u671f\u524d\u4f86\uff0c\u53e4\u4ead\u8b80\u66f8\u6703\u7279\u5225\u5b89\u6392\u4e09\u6b21\u300c\u77ad\u89e3\u751f\u547d\u3001\u660e\u767d\u4e0a\u8def\u300d\u6d3b\u52d5\uff0c\u524d\u5169\u6b21\u662f\u5206\u4eab\u8207\u8a0e\u8ad6\uff0c\u7b2c\u4e09\u6b21\u662f\u5169\u5929\u4e00\u591c\u7684\u6df1\u5ea6\u5c0d\u8a71\u3002\u70ba\u4e86\u8fa6\u597d\u6d3b\u52d5\uff0c\u7e3d \u6709\u4e9b\u5fc5\u8981\u7684\u4e8b\u524d\u5354\u5546\u8207\u76f8\u4e92\u77ad\u89e3\uff0c\u6211\u8207\u5e7e\u4f4d\u597d\u53cb\u591a\u6b21\u81f3\u6771\u5317\u8001\u5e2b\u8207\u5e2b\u6bcd\u4e0b\u891f\u65c5\u9928\u9020\u8a2a\uff0c\u6bcf\u6b21\u90fd\u6709\u597d\u591a\u4eba\u5411\u4ed6\u8acb\u6559\u6709\u95dc\u4fee\u884c\u8207\u751f\u547d\u7684\u8af8\u591a\u554f\u984c\u3002\u5728\u554f\u7b54\u4e4b\u9593\uff0c\u6211\u6709\u4e00\u7a2e\u76f4\u89ba\uff0c\u6771\u5317\u8001\u5e2b\u662f\u4e00\u4f4d\u76f8\u7576\u6709\u6df1\u5ea6\u7684\u4eba\u3002\u4f46\u7531\u65bc\u63d0\u554f\u984c\u7684\u4eba\u592a\u591a\uff0c\u554f\u984c\u4e5f\u5f88\u96dc\uff0c\u7121\u6cd5\u7531\u5e7e\u6b21\u6703\u9762\u4e2d\u6574\u7406\u51fa\u6771\u5317\u8001\u5e2b\u7684\u601d\u60f3\u9ad4\u7cfb\uff0c\u96d6\u7136\u6bcf\u6b21\u9020\u8a2a\u90fd\u5728\u665a\u4e0a\u5341\u4e8c\u9ede\u5f8c\uff0c\u61f7 \u8457\u4e0d\u6368\u8207\u4e0d\u60c5\u9858\u7684\u5fc3\u60c5\u96e2\u53bb\u3002<\/p>\n<p><img loading=\"lazy\" class=\"alignleft size-medium wp-image-413\" title=\"\u53e4\u4ead\u8b80\u66f8\u6703\u6f14\u8b1b\" src=\"http:\/\/www.is-zen.org\/tc\/wp-content\/uploads\/2010\/03\/P5149316_480-300x225.jpg\" alt=\"\u53e4\u4ead\u8b80\u66f8\u6703\u6f14\u8b1b\" width=\"300\" height=\"225\" srcset=\"http:\/\/www.is-zen.org\/tc\/wp-content\/uploads\/2010\/03\/P5149316_480-300x225.jpg 300w, http:\/\/www.is-zen.org\/tc\/wp-content\/uploads\/2010\/03\/P5149316_480.jpg 480w\" sizes=\"(max-width: 300px) 100vw, 300px\" \/>\u5169\u6b21\u300c\u77ad\u89e3\u751f\u547d\u3001\u660e\u767d\u4e0a\u8def\u300d\u5206\u4eab\u8207\u8a0e\u8ad6\u6d3b\u52d5\uff0c\u5206\u5225\u5728\u661f\u671f\u4e8c\u8207\u661f\u671f\u4e94\u665a\u4e0a\u4e03\u6642\u8209\u884c\uff0c\u901a\u5e38\u9019\u7a2e\u6642\u6bb5\u7684\u6d3b\u52d5\uff0c\u4e0d\u6703\u6709\u592a\u591a\u4eba\u53c3\u52a0\u3002\u6c92\u60f3\u5230\uff0c\u661f\u671f\u4e8c\u7adf\u7136\u6709\u4e09\u5341 \u4e94\u4eba\u53c3\u52a0\uff0c\u661f\u671f\u4e94\u66f4\u662f\u8d85\u904e\u4e86\u56db\u5341\u4eba\uff0c\u6253\u7834\u4e86\u53e4\u4ead\u8b80\u66f8\u6703\u6d3b\u52d5\u7684\u53c3\u52a0\u4eba\u6578\u7d00\u9304\uff0c\u5c07\u5c0f\u5c0f\u5834\u5730\u64e0\u5f97\u6c34\u6d29\u4e0d\u901a\u3002\u7e31\u4f7f\u53c3\u52a0\u6d3b\u52d5\u7684\u4eba\u5f88\u591a\uff0c\u63d0\u51fa\u7684\u554f\u984c\u4e5f\u4e0d\u5c11\uff0c\u4f46\u4ecd\u7136\u96e3\u4ee5 \u77ad\u89e3\u6771\u5317\u8001\u5e2b\u5230\u5e95\u6709\u4ec0\u9ebc\u9b54\u529b\uff0c\u8b93\u5b78\u751f\u5011\u6b7b\u5fc3\u584c\u5730\u7684\u8ddf\u8457\u4ed6\u3002\u53ea\u662f\u7531\u4ed6\u7684\u8ad6\u8ff0\u4e2d\uff0c\u591a\u4e86\u4e00\u9ede\u77ad\u89e3\uff0c\u300c\u89c0\u5bdf\u300d\u5f88\u91cd\u8981\u3002<\/p>\n<p>\u7b2c\u4e09\u6b21\u300c\u77ad\u89e3\u751f\u547d\u3001\u660e\u767d\u4e0a\u8def\u300d\u6df1\u5ea6\u5c0d\u8a71\u6d3b\u52d5\uff0c\u5728\u6728\u67f5\u7684\u5927\u6625\u5c71\u838a\u8209\u8fa6\uff0c\u7d04\u6709\u4e09\u5341\u4eba\u53c3\u52a0\uff0c\u661f\u671f\u516d\u4e0a\u5348\u5341\u9ede\u5de6\u53f3\uff0c\u5925\u4f34\u5011\u9678\u7e8c\u62b5\u9054\u6d3b\u52d5\u5730\u9ede\u3002\u5348\u9910\u524d\u539f\u8a02\u7684\u81ea\u7531\u6d3b\u52d5\u6642\u9593\uff0c\u5927\u5bb6\u7adf\u7136\u4e0d\u7d04\u800c\u540c\u5730\u570d\u8457\u6771\u5317\u8001\u5e2b\u8a0e\u8ad6\u8d77\u4f86\uff0c\u597d\u50cf\u4e0d\u60f3\u932f\u904e\u4efb\u4f55\u5411\u4ed6\u8a0e\u6559\u7684\u6a5f\u6703\u3002\u5169\u5929\u4e00\u591c\u6d3b\u52d5\u4e0b\u4f86\uff0c\u6211\u624d\u6f38\u6f38\u660e\u767d\uff0c\u6771\u5317\u8001\u5e2b\u66fe\u95b1\u8b80\u5927\u91cf\u4f5b\u5178\u3001\u9053\u85cf\u3001\u65b0\u6642\u4ee3\u7b49\u5fc3\u9748\u8207\u4fee\u884c\u76f8\u95dc\u66f8\u7c4d\uff0c\u52a0\u4e0a\u6578\u5341\u5e74\u7684\u5be6\u4fee\u5be6\u8b49\uff0c\u65e9\u5df2\u878d\u6703\u8cab\u901a\uff0c\u5f62\u6210\u4e00\u5b8c\u6574\u9ad4\u7cfb\u3002\u5c24\u5176\u4ed6\u89e3\u8aaa\u4f5b\u6cd5\u8981\u7fa9\uff0c\u66f4\u662f\u7c21\u55ae\u660e\u78ba\uff0c\u6bcf\u4e00\u53e5\u8a71\u90fd\u93d7\u93d8\u6709\u529b\uff0c\u555f\u767c\u4eba\u5fc3\u3002\u96e3\u602a\u5927\u5bb6\u90fd\u60f3\u8ddf\u5728\u4ed6\u8eab\u908a\uff0c\u62fc\u547d\u7684\u6316\u5bf6\uff0c\u7136\u800c\uff0c\u4ed6\u5c31\u50cf\u500b\u6316\u4e0d\u76e1\u7684\u5bf6\u85cf\uff0c\u4efb\u6191\u6316\u6398\uff0c\u96a8\u6642\u90fd\u6709\u9bae\u6d3b\u7684\u77e5\u898b\u3001\u5d84\u65b0\u7684\u9ad4\u6703\u3002<\/p>\n<h3>\u7a76\u7adf\u7684\u9053\u7406<\/h3>\n<p>\u5c07\u8fd1\u5341\u5e74\u7684\u5fc3\u9748\u63a2\u7d22\u6b77\u7a0b\uff0c\u6211\u5fc3\u88e1\u6f38\u6f38\u5f62\u6210\u4e86\u4e00\u4e9b\u6709\u95dc\u751f\u547d\u8207\u4fee\u884c\u7684\u6982\u5ff5\uff0c\u8af8\u5982\uff1a\u4fe1\u5ff5\u5275\u9020\u5be6\u76f8\u3001\u6211\u5011\u90fd\u662f\u4e00\u5207\u842c\u6709\u7684\u4e00\u90e8\u4efd\u3001\u6211\u5011\u662f\u4e00\u9ad4\u7684\u3001\u6211\u5011\u5df2\u5713\u6eff\u5177 \u8db3\u3001\u4e0d\u9700\u8981\u518d\u591a\u505a\u4ec0\u9ebc\u4f7f\u81ea\u5df1\u66f4\u597d\u3001\u51e1\u4e8b\u6c92\u6709\u4ec0\u9ebc\u597d\u8207\u58de\u3001\u6211\u5011\u61c9\u6b23\u7136\u63a5\u53d7\u4e00\u5207\u7b49\u7b49\u3002\u4f46\u662f\uff0c\u9019\u4e9b\u89c0\u5ff5\u5c0d\u6211\u800c\u8a00\uff0c\u53ea\u662f\u4e00\u7a2e\u77e5\u8b58\u6216\u7406\u89e3\u3002\u5fc3\u5883\u5e73\u9806\u6642\uff0c\u5c1a\u53ef\u5b89\u7136\u81ea \u8655\uff1b\u601d\u616e\u7169\u96dc\u6642\uff0c\u5f88\u5c11\u6703\u60f3\u5230\u9019\u4e9b\u9053\u7406\uff0c\u5e38\u5e38\u4efb\u7531\u539a\u91cd\u7684\u7fd2\u6027\u64fa\u4f48\u800c\u4e0d\u81ea\u89ba\u3002\u5176\u5be6\uff0c\u9019\u4e5f\u610f\u5473\u8457\uff0c\u6211\u5c0d\u9019\u4e9b\u9053\u7406\u7684\u77ad\u89e3\u8207\u9ad4\u6703\u4e0d\u5920\u6df1\u523b\uff0c\u4ee5\u81f3\u65bc\u5728\u751f\u6d3b\u88e1\uff0c\u96e3\u4ee5\u767c\u63ee \u4ec0\u9ebc\u4f5c\u7528\u3002<\/p>\n<p>\u7d93\u904e\u4e00\u9023\u4e32\u7684\u807d\u8b1b\u3001\u554f\u7b54\uff0c\u751a\u81f3\u65bc\u722d\u8faf\uff0c\u6211\u7531\u6771\u5317\u8001\u5e2b\u7684\u8a71\u8a9e\u4e2d\uff0c\u7d42\u65bc\u627e\u5230\u4e9b\u8b93\u6211\u611f\u5230\u6975\u70ba\u8208\u596e\u7684\u767c\u73fe\u3002\u4ee5\u5f80\u6211\u4e5f\u77e5\u9053\uff0c\u89c0\u5bdf\u5f88\u91cd\u8981\uff0c\u4f46\u662f\uff0c\u6c92\u60f3\u5230\u662f\u9019\u9ebc\u91cd \u8981\u3001\u5982\u6b64\u7a76\u7adf\u3002\u6771\u5317\u8001\u5e2b\u900f\u904e\u591a\u90e8\u91cd\u8981\u4f5b\u5178\uff0c\u53cd\u8986\u89e3\u8aaa\u5176\u4e2d\u5c0d\u89c0\u5bdf\u7684\u95e1\u8ff0\u8207\u8981\u7fa9\uff0c\u6700\u5f8c\uff0c\u7adf\u7136\u662f\u6240\u6709\u4f5b\u5178\u90fd\u5728\u8ad6\u8ff0\u9019\u4e00\u4ef6\u4e8b\uff1b\u751a\u81f3\u65bc\u6c23\u529f\u3001\u9053\u6cd5\u3001\u85cf\u5bc6\u7684\u6700\u9ad8\u79d8\u6cd5\uff0c \u4e5f\u90fd\u662f\u7d14\u7136\u7684\u89c0\u5bdf\u3002\u900f\u904e\u89c0\u5bdf\uff0c\u53ef\u4ee5\u77ad\u89e3\u81ea\u6211\u3001\u89e3\u6c7a\u56f0\u9628\uff1b\u900f\u904e\u89c0\u5bdf\uff0c\u53ef\u4ee5\u7834\u9664\u8ff7\u5984\u3001\u8fd4\u749e\u6b78\u771f\uff1b\u900f\u904e\u89c0\u5bdf\uff0c\u53ef\u4ee5\u660e\u5fc3\u898b\u6027\u3001\u76f4\u4e86\u6210\u4f5b\u3002<\/p>\n<p>\u4ee5\u5f80\uff0c\u9762\u81e8\u56f0\u9813\u8207\u9006\u5883\u6642\uff0c\u6211\u6703\u544a\u8a34\u81ea\u5df1\uff0c\u4e00\u5207\u90fd\u662f\u6700\u597d\u7684\u5b89\u6392\uff0c\u8981\u611f\u8b1d\u8b93\u6211\u50b7\u75db\u7684\u4eba\u8207\u4e8b\u7269\uff0c\u4ed6\u5011\u8b93\u6211\u6709\u6a5f\u6703\u6210\u9577\u8301\u58ef\u3002\u6240\u4ee5\uff0c\u6709\u6642\u5019\u670b\u53cb\u8207\u6211\u8ac7\u5230\u5fc3\u4e2d\u7684 \u611f\u50b7\u6216\u75db\u82e6\uff0c\u6211\u4e5f\u6703\u4ee5\u540c\u6a23\u7684\u8a71\uff0c\u52f8\u4ed6\u5011\u611f\u8b1d\u3001\u63a5\u53d7\u9019\u4e00\u5207\u3002\u4f46\u662f\uff0c\u6211\u77e5\u9053\u9019\u8a71\u8aaa\u5f97\u5f88\u52c9\u5f37\u3002\u7562\u7adf\uff0c\u81ea\u5df1\u591a\u5e74\u524d\u7684\u50b7\uff0c\u4ecd\u96b1\u96b1\u5728\u75db\uff0c\u4e26\u6c92\u6709\u771f\u6b63\u7684\u5e73\u5fa9\u3002\u73fe\u5728\uff0c\u518d\u6709 \u50b7\u75db\uff0c\u6211\u6703\u6539\u4ee5\u4e0d\u5e36\u8a55\u5224\u7684\u89c0\u5bdf\uff0c\u5617\u8a66\u53bb\u770b\u6e05\u695a\u767c\u751f\u904e\u7a0b\u8207\u771f\u6b63\u7684\u611f\u53d7\uff0c\u6211\u6df1\u4fe1\uff0c\u89c0\u5bdf\u662f\u6709\u529b\u91cf\u7684\uff0c\u5b83\u6703\u5f15\u9818\u6211\u5011\u89e3\u6c7a\u4e00\u5207\u554f\u984c\u3002<\/p>\n<p>\u4e0d\u5e36\u8a55\u5224\u7684\u89c0\u5bdf\uff0c\u8aaa\u8d77\u4f86\u5bb9\u6613\uff0c\u505a\u8d77\u4f86\u53ef\u4e0d\u662f\u90a3\u9ebc\u7c21\u55ae\uff0c\u56e0\u70ba\u982d\u8166\u592a\u904e\u5805\u5be6\uff0c\u5f88\u96e3\u64fa\u812b\u5b83\u7684\u638c\u63a7\u3002\u4e8b\u5be6\u4e0a\uff0c\u6211\u89c0\u5bdf\u81ea\u5df1\u4e5f\u6709\u516d\u3001\u4e03\u5e74\u4e86\uff0c\u5e73\u6642\u5e38\u5e38\u63d0\u9192\u81ea\u5df1\u653e \u9b06\uff0c\u96a8\u6642\u89c0\u5bdf\u8eab\u9ad4\u611f\u89ba\u8207\u5fc3\u5ff5\uff0c\u9577\u6b64\u4ee5\u5f80\uff0c\u6f38\u6f38\u990a\u6210\u4e86\u7fd2\u6163\uff0c\u60c5\u7dd2\u8d77\u4f0f\u7a0d\u5fae\u5927\u4e00\u4e9b\uff0c\u5c31\u6703\u81ea\u52d5\u7684\u53bb\u89c0\u5bdf\u5fc3\u5ff5\u3002\u4f46\u662f\uff0c\u4e5f\u5c31\u662f\u9019\u6a23\u4e86\uff0c\u5728\u5fc3\u9748\u6210\u9577\u65b9\u9762\uff0c\u4f3c\u4e4e\u5df2\u5728\u539f\u5730 \u8e0f\u6b65\u4e86\u597d\u9577\u4e00\u6bb5\u6642\u9593\u3002\u8207\u6771\u5317\u8001\u5e2b\u76f8\u8655\u9019\u6bb5\u6642\u9593\uff0c\u6211\u767c\u73fe\u4ed6\u9664\u4e86\u6559\u5c0e\u4fee\u884c\u7684\u9053\u7406\u4e4b\u5916\uff0c\u66f4\u96e3\u80fd\u53ef\u8cb4\u7684\u662f\uff0c\u4ed6\u9084\u6709\u4e00\u5957\u56b4\u8b39\u7684\u4fee\u884c\u65b9\u6cd5\uff0c\u6709\u6b21\u7b2c\u7684\u5f15\u9818\u5927\u5bb6\u4e00\u6b65\u6b65\u5730\u964d \u4f0f\u982d\u8166\uff0c\u6253\u958b\u5fc3\u6249\uff0c\u7522\u751f\u6e05\u660e\u667a\u6167\u3002<\/p>\n<h3>\u96e3\u4ee5\u8a00\u55bb\u7684\u78ba\u4fe1<\/h3>\n<p>\u6211\u66fe\u96dc\u4e03\u96dc\u516b\u5730\u770b\u904e\u4e00\u4e9b\u63a2\u7a76\u751f\u547d\u3001\u5fc3\u9748\u8207\u4fee\u884c\u65b9\u9762\u7684\u66f8\uff0c\u52a0\u4e0a\u7d93\u5e38\u53c3\u8207\u8b80\u66f8\u6703\u3001\u5ea7\u8ac7\u6703\u7b49\u6d3b\u52d5\uff0c\u54ea\u4e9b\u9053\u7406\u8aaa\u5f97\u901a\uff0c\u54ea\u4e9b\u89c0\u5ff5\u592a\u504f\u9817\uff0c\u5728\u6211\u5fc3\u4e2d\u81ea\u6709\u4e00\u5957\u6aa2\u9a57 \u7684\u539f\u5247\u3002\u4f8b\u5982\uff1a\u662f\u5426\u7d93\u5f97\u8d77\u6642\u9593\u8003\u9a57\uff1f\u662f\u5426\u653e\u8af8\u56db\u6d77\u7686\u6e96\uff1f\u662f\u5426\u4fb7\u9650\u65bc\u67d0\u4e9b\u6846\u67b6\uff1f\u662f\u5426\u6709\u6240\u57f7\u53d6\u3001\u5f37\u8abf\u6240\u6c42\u8207\u6240\u5f97\uff1f\u662f\u5426\u80fd\u5728\u751f\u6d3b\u4e2d\u5be6\u8e10\uff1f\u7b49\u7b49\u3002\u6771\u5317\u8001\u5e2b\u6240\u8ac7\u7684\u9053 \u7406\u8207\u7df4\u7fd2\u65b9\u6cd5\uff0c\u4e0d\u4f46\u8d85\u8d8a\u4e86\u6211\u6240\u6709\u7684\u6aa2\u9a57\u539f\u5247\uff0c\u800c\u4e14\uff0c\u8b93\u6211\u5728\u76f4\u89ba\u4e0a\u7522\u751f\u4e00\u4efd\u96e3\u4ee5\u8a00\u55bb\u7684\u78ba\u4fe1\uff0c\u90a3\u5c31\u662f\u4e86\uff01\u5c24\u5176\u4ed6\u7684\u8a00\u884c\u98a8\u7bc4\uff0c\u4e00\u518d\u8b93\u4eba\u611f\u53d7\u5230\u90a3\u7a2e\u6700\u4e0d\u5e73\u51e1\u7684\u5e73\u51e1\u3002<\/p>\n<p>\u6b64\u6642\u6b64\u523b\uff0c\u6771\u5317\u8001\u5e2b\u8207\u5e2b\u6bcd\u9084\u5728\u53f0\u7063\uff0c\u4f46\u6211\u5fc3\u88e1\u5df2\u7136\u6607\u8d77\u4e00\u9663\u6de1\u6de1\u7684\u96e2\u6101\uff0c\u96d6\u7136\u660e\u5929\u9084\u6703\u548c\u4ed6\u5011\u898b\u9762\u3002\u9019\u6bb5\u6642\u9593\u5c0d\u6211\u800c\u8a00\uff0c\u6709\u4e00\u7a2e\u8fd1\u4e4e\u300c\u671d\u805e\u9053\uff0c\u5915\u6b7b\u53ef\u77e3\uff01\u300d\u7684\u5fc3\u60c5\uff0c\u53d7\u76ca\u826f\u591a\u8207\u8877\u5fc3\u611f\u8b1d\u7b49\u6587\u8a5e\uff0c\u5747\u7121\u6cd5\u5f62\u5bb9\u5167\u5fc3\u7684\u611f\u53d7\uff0c\u8b39\u4ee5\u6b64\u6587\u9298\u8a18\u3002\u540c\u6642\uff0c\u6211\u6703\u9806\u5f9e\u90a3\u4efd\u78ba\u4fe1\uff0c\u5728\u5fc3\u7530\u57cb\u4e0b\u4e00\u7c92\u91d1\u525b\u89c0\u5bdf\u7684\u7a2e\u7c7d\uff0c\u76fc\u80fd\u900f\u904e\u89c0\u5bdf\u3001 \u89c0\u5bdf\u3001\u518d\u89c0\u5bdf\uff0c\u4e0d\u8ca0\u6771\u5317\u8001\u5e2b\u5fc3\u610f\u3002<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u6316\u4e0d\u76e1\u7684\u5bf6\u85cf \u4eca\u5e74\u4e00\u6708\uff0c\u53e4\u4ead\u8b80\u66f8\u6703\u8209\u8fa6\u4ee5\u300c\u751f\u547d\u7684\u9053\u8def\u300d\u70ba\u984c\u4e4b\u5206\u4eab\u8207\u8a0e\u8ad6\u6d3b\u52d5\uff0c\u65b0\u5a5a\u4e0d\u4e45\u7684 Vivian \u8207 Monte \u5e36\u9818\u9019\u6b21\u6d3b\u52d5\uff0c\u4ed6\u5011\u5728\u5206\u4eab\u8207\u8a0e\u8ad6\u904e\u7a0b\u4e2d\uff0c\u983b\u983b\u63d0\u53ca\u5728\u7f8e\u570b\u7684\u6771\u5317\u8001\u5e2b\uff0c\u5982\u4f55\u8b93\u4ed6\u5011\u77ad\u89e3\u300c\u6211\u300d\u3001\u300c\u751f\u547d\u300d\u3001\u300c\u4fee\u884c\u300d\u7b49\u8af8\u591a\u8981\u7fa9\uff0c\u4e26\u6559\u5c0e\u4ed6\u5011\u5982\u5be6\u89c0\u7167\u3001\u5168\u7136\u63a5 \u53d7\u3001\u5e6b\u52a9\u4ed6\u5011\u91d0\u6e05\u8a31\u591a\u77db\u76fe\u3001\u5f15\u5c0e\u4ed6\u5011\u8d70\u4e0a\u6b63\u78ba\u7684\u9053\u8def\u3001\u5fb9\u5e95\u6539\u8b8a\u4e86\u4ed6\u5011\u7684\u751f\u6d3b\u614b\u5ea6\u8207\u65b9\u5f0f\u3002\u7576\u6642\uff0c\u53c3\u8207\u6d3b\u52d5\u8005\u5747\u5c0d\u6771\u5317\u8001\u5e2b\u662f\u4ec0\u9ebc\u6a23\u7684\u4eba\uff0c\u70ba\u4f55\u6703\u5c0d\u4eba\u9020\u6210\u9019\u9ebc\u5927 \u7684\u5f71\u97ff\uff0c\u611f\u5230\u5341\u5206\u597d\u5947\u3002Vivian \u8207 Monte \u5728\u6d3b\u52d5\u7d50\u675f\u524d\u9810\u544a\uff0c\u6771\u5317\u8001\u5e2b\u5c07\u65bc\u4e94\u6708\u4f86\u53f0\uff0c\u5927\u5bb6\u90fd\u597d\u8208\u596e\uff0c\u8868\u793a\u4e00\u5b9a\u4e0d\u80fd\u932f\u904e\u9019\u500b\u6a5f\u6703\u3002 \u4e94\u6708\uff0c\u6771\u5317\u8001\u5e2b\u5982\u671f\u524d\u4f86\uff0c\u53e4\u4ead\u8b80\u66f8\u6703\u7279\u5225\u5b89\u6392\u4e09\u6b21\u300c\u77ad\u89e3\u751f\u547d\u3001\u660e\u767d\u4e0a\u8def\u300d\u6d3b\u52d5\uff0c\u524d\u5169\u6b21\u662f\u5206\u4eab\u8207\u8a0e\u8ad6\uff0c\u7b2c\u4e09\u6b21\u662f\u5169\u5929\u4e00\u591c\u7684\u6df1\u5ea6\u5c0d\u8a71\u3002\u70ba\u4e86\u8fa6\u597d\u6d3b\u52d5\uff0c\u7e3d \u6709\u4e9b\u5fc5\u8981\u7684\u4e8b\u524d\u5354\u5546\u8207\u76f8\u4e92\u77ad\u89e3\uff0c\u6211\u8207\u5e7e\u4f4d\u597d\u53cb\u591a\u6b21\u81f3\u6771\u5317\u8001\u5e2b\u8207\u5e2b\u6bcd\u4e0b\u891f\u65c5\u9928\u9020\u8a2a\uff0c\u6bcf\u6b21\u90fd\u6709\u597d\u591a\u4eba\u5411\u4ed6\u8acb\u6559\u6709\u95dc\u4fee\u884c\u8207\u751f\u547d\u7684\u8af8\u591a\u554f\u984c\u3002\u5728\u554f\u7b54\u4e4b\u9593\uff0c\u6211\u6709\u4e00\u7a2e\u76f4\u89ba\uff0c\u6771\u5317\u8001\u5e2b\u662f\u4e00\u4f4d\u76f8\u7576\u6709\u6df1\u5ea6\u7684\u4eba\u3002\u4f46\u7531\u65bc\u63d0\u554f\u984c\u7684\u4eba\u592a\u591a\uff0c\u554f\u984c\u4e5f\u5f88\u96dc\uff0c\u7121\u6cd5\u7531\u5e7e\u6b21\u6703\u9762\u4e2d\u6574\u7406\u51fa\u6771\u5317\u8001\u5e2b\u7684\u601d\u60f3\u9ad4\u7cfb\uff0c\u96d6\u7136\u6bcf\u6b21\u9020\u8a2a\u90fd\u5728\u665a\u4e0a\u5341\u4e8c\u9ede\u5f8c\uff0c\u61f7 \u8457\u4e0d\u6368\u8207\u4e0d\u60c5\u9858\u7684\u5fc3\u60c5\u96e2\u53bb\u3002 \u5169\u6b21\u300c\u77ad\u89e3\u751f\u547d\u3001\u660e\u767d\u4e0a\u8def\u300d\u5206\u4eab\u8207\u8a0e\u8ad6\u6d3b\u52d5\uff0c\u5206\u5225\u5728\u661f\u671f\u4e8c\u8207\u661f\u671f\u4e94\u665a\u4e0a\u4e03\u6642\u8209\u884c\uff0c\u901a\u5e38\u9019\u7a2e\u6642\u6bb5\u7684\u6d3b\u52d5\uff0c\u4e0d\u6703\u6709\u592a\u591a\u4eba\u53c3\u52a0\u3002\u6c92\u60f3\u5230\uff0c\u661f\u671f\u4e8c\u7adf\u7136\u6709\u4e09\u5341 \u4e94\u4eba\u53c3\u52a0\uff0c\u661f\u671f\u4e94\u66f4\u662f\u8d85\u904e\u4e86\u56db\u5341\u4eba\uff0c\u6253\u7834\u4e86\u53e4\u4ead\u8b80\u66f8\u6703\u6d3b\u52d5\u7684\u53c3\u52a0\u4eba\u6578\u7d00\u9304\uff0c\u5c07\u5c0f\u5c0f\u5834\u5730\u64e0\u5f97\u6c34\u6d29\u4e0d\u901a\u3002\u7e31\u4f7f\u53c3\u52a0\u6d3b\u52d5\u7684\u4eba\u5f88\u591a\uff0c\u63d0\u51fa\u7684\u554f\u984c\u4e5f\u4e0d\u5c11\uff0c\u4f46\u4ecd\u7136\u96e3\u4ee5 \u77ad\u89e3\u6771\u5317\u8001\u5e2b\u5230\u5e95\u6709\u4ec0\u9ebc\u9b54\u529b\uff0c\u8b93\u5b78\u751f\u5011\u6b7b\u5fc3\u584c\u5730\u7684\u8ddf\u8457\u4ed6\u3002\u53ea\u662f\u7531\u4ed6\u7684\u8ad6\u8ff0\u4e2d\uff0c\u591a\u4e86\u4e00\u9ede\u77ad\u89e3\uff0c\u300c\u89c0\u5bdf\u300d\u5f88\u91cd\u8981\u3002 \u7b2c\u4e09\u6b21\u300c\u77ad\u89e3\u751f\u547d\u3001\u660e\u767d\u4e0a\u8def\u300d\u6df1\u5ea6\u5c0d\u8a71\u6d3b\u52d5\uff0c\u5728\u6728\u67f5\u7684\u5927\u6625\u5c71\u838a\u8209\u8fa6\uff0c\u7d04\u6709\u4e09\u5341\u4eba\u53c3\u52a0\uff0c\u661f\u671f\u516d\u4e0a\u5348\u5341\u9ede\u5de6\u53f3\uff0c\u5925\u4f34\u5011\u9678\u7e8c\u62b5\u9054\u6d3b\u52d5\u5730\u9ede\u3002\u5348\u9910\u524d\u539f\u8a02\u7684\u81ea\u7531\u6d3b\u52d5\u6642\u9593\uff0c\u5927\u5bb6\u7adf\u7136\u4e0d\u7d04\u800c\u540c\u5730\u570d\u8457\u6771\u5317\u8001\u5e2b\u8a0e\u8ad6\u8d77\u4f86\uff0c\u597d\u50cf\u4e0d\u60f3\u932f\u904e\u4efb\u4f55\u5411\u4ed6\u8a0e\u6559\u7684\u6a5f\u6703\u3002\u5169\u5929\u4e00\u591c\u6d3b\u52d5\u4e0b\u4f86\uff0c\u6211\u624d\u6f38\u6f38\u660e\u767d\uff0c\u6771\u5317\u8001\u5e2b\u66fe\u95b1\u8b80\u5927\u91cf\u4f5b\u5178\u3001\u9053\u85cf\u3001\u65b0\u6642\u4ee3\u7b49\u5fc3\u9748\u8207\u4fee\u884c\u76f8\u95dc\u66f8\u7c4d\uff0c\u52a0\u4e0a\u6578\u5341\u5e74\u7684\u5be6\u4fee\u5be6\u8b49\uff0c\u65e9\u5df2\u878d\u6703\u8cab\u901a\uff0c\u5f62\u6210\u4e00\u5b8c\u6574\u9ad4\u7cfb\u3002\u5c24\u5176\u4ed6\u89e3\u8aaa\u4f5b\u6cd5\u8981\u7fa9\uff0c\u66f4\u662f\u7c21\u55ae\u660e\u78ba\uff0c\u6bcf\u4e00\u53e5\u8a71\u90fd\u93d7\u93d8\u6709\u529b\uff0c\u555f\u767c\u4eba\u5fc3\u3002\u96e3\u602a\u5927\u5bb6\u90fd\u60f3\u8ddf\u5728\u4ed6\u8eab\u908a\uff0c\u62fc\u547d\u7684\u6316\u5bf6\uff0c\u7136\u800c\uff0c\u4ed6\u5c31\u50cf\u500b\u6316\u4e0d\u76e1\u7684\u5bf6\u85cf\uff0c\u4efb\u6191\u6316\u6398\uff0c\u96a8\u6642\u90fd\u6709\u9bae\u6d3b\u7684\u77e5\u898b\u3001\u5d84\u65b0\u7684\u9ad4\u6703\u3002 \u7a76\u7adf\u7684\u9053\u7406 \u5c07\u8fd1\u5341\u5e74\u7684\u5fc3\u9748\u63a2\u7d22\u6b77\u7a0b\uff0c\u6211\u5fc3\u88e1\u6f38\u6f38\u5f62\u6210\u4e86\u4e00\u4e9b\u6709\u95dc\u751f\u547d\u8207\u4fee\u884c\u7684\u6982\u5ff5\uff0c\u8af8\u5982\uff1a\u4fe1\u5ff5\u5275\u9020\u5be6\u76f8\u3001\u6211\u5011\u90fd\u662f\u4e00\u5207\u842c\u6709\u7684\u4e00\u90e8\u4efd\u3001\u6211\u5011\u662f\u4e00\u9ad4\u7684\u3001\u6211\u5011\u5df2\u5713\u6eff\u5177 \u8db3\u3001\u4e0d\u9700\u8981\u518d\u591a\u505a\u4ec0\u9ebc\u4f7f\u81ea\u5df1\u66f4\u597d\u3001\u51e1\u4e8b\u6c92\u6709\u4ec0\u9ebc\u597d\u8207\u58de\u3001\u6211\u5011\u61c9\u6b23\u7136\u63a5\u53d7\u4e00\u5207\u7b49\u7b49\u3002\u4f46\u662f\uff0c\u9019\u4e9b\u89c0\u5ff5\u5c0d\u6211\u800c\u8a00\uff0c\u53ea\u662f\u4e00\u7a2e\u77e5\u8b58\u6216\u7406\u89e3\u3002\u5fc3\u5883\u5e73\u9806\u6642\uff0c\u5c1a\u53ef\u5b89\u7136\u81ea \u8655\uff1b\u601d\u616e\u7169\u96dc\u6642\uff0c\u5f88\u5c11\u6703\u60f3\u5230\u9019\u4e9b\u9053\u7406\uff0c\u5e38\u5e38\u4efb\u7531\u539a\u91cd\u7684\u7fd2\u6027\u64fa\u4f48\u800c\u4e0d\u81ea\u89ba\u3002\u5176\u5be6\uff0c\u9019\u4e5f\u610f\u5473\u8457\uff0c\u6211\u5c0d\u9019\u4e9b\u9053\u7406\u7684\u77ad\u89e3\u8207\u9ad4\u6703\u4e0d\u5920\u6df1\u523b\uff0c\u4ee5\u81f3\u65bc\u5728\u751f\u6d3b\u88e1\uff0c\u96e3\u4ee5\u767c\u63ee \u4ec0\u9ebc\u4f5c\u7528\u3002 \u7d93\u904e\u4e00\u9023\u4e32\u7684\u807d\u8b1b\u3001\u554f\u7b54\uff0c\u751a\u81f3\u65bc\u722d\u8faf\uff0c\u6211\u7531\u6771\u5317\u8001\u5e2b\u7684\u8a71\u8a9e\u4e2d\uff0c\u7d42\u65bc\u627e\u5230\u4e9b\u8b93\u6211\u611f\u5230\u6975\u70ba\u8208\u596e\u7684\u767c\u73fe\u3002\u4ee5\u5f80\u6211\u4e5f\u77e5\u9053\uff0c\u89c0\u5bdf\u5f88\u91cd\u8981\uff0c\u4f46\u662f\uff0c\u6c92\u60f3\u5230\u662f\u9019\u9ebc\u91cd \u8981\u3001\u5982\u6b64\u7a76\u7adf\u3002\u6771\u5317\u8001\u5e2b\u900f\u904e\u591a\u90e8\u91cd\u8981\u4f5b\u5178\uff0c\u53cd\u8986\u89e3\u8aaa\u5176\u4e2d\u5c0d\u89c0\u5bdf\u7684\u95e1\u8ff0\u8207\u8981\u7fa9\uff0c\u6700\u5f8c\uff0c\u7adf\u7136\u662f\u6240\u6709\u4f5b\u5178\u90fd\u5728\u8ad6\u8ff0\u9019\u4e00\u4ef6\u4e8b\uff1b\u751a\u81f3\u65bc\u6c23\u529f\u3001\u9053\u6cd5\u3001\u85cf\u5bc6\u7684\u6700\u9ad8\u79d8\u6cd5\uff0c \u4e5f\u90fd\u662f\u7d14\u7136\u7684\u89c0\u5bdf\u3002\u900f\u904e\u89c0\u5bdf\uff0c\u53ef\u4ee5\u77ad\u89e3\u81ea\u6211\u3001\u89e3\u6c7a\u56f0\u9628\uff1b\u900f\u904e\u89c0\u5bdf\uff0c\u53ef\u4ee5\u7834\u9664\u8ff7\u5984\u3001\u8fd4\u749e\u6b78\u771f\uff1b\u900f\u904e\u89c0\u5bdf\uff0c\u53ef\u4ee5\u660e\u5fc3\u898b\u6027\u3001\u76f4\u4e86\u6210\u4f5b\u3002 \u4ee5\u5f80\uff0c\u9762\u81e8\u56f0\u9813\u8207\u9006\u5883\u6642\uff0c\u6211\u6703\u544a\u8a34\u81ea\u5df1\uff0c\u4e00\u5207\u90fd\u662f\u6700\u597d\u7684\u5b89\u6392\uff0c\u8981\u611f\u8b1d\u8b93\u6211\u50b7\u75db\u7684\u4eba\u8207\u4e8b\u7269\uff0c\u4ed6\u5011\u8b93\u6211\u6709\u6a5f\u6703\u6210\u9577\u8301\u58ef\u3002\u6240\u4ee5\uff0c\u6709\u6642\u5019\u670b\u53cb\u8207\u6211\u8ac7\u5230\u5fc3\u4e2d\u7684 \u611f\u50b7\u6216\u75db\u82e6\uff0c\u6211\u4e5f\u6703\u4ee5\u540c\u6a23\u7684\u8a71\uff0c\u52f8\u4ed6\u5011\u611f\u8b1d\u3001\u63a5\u53d7\u9019\u4e00\u5207\u3002\u4f46\u662f\uff0c\u6211\u77e5\u9053\u9019\u8a71\u8aaa\u5f97\u5f88\u52c9\u5f37\u3002\u7562\u7adf\uff0c\u81ea\u5df1\u591a\u5e74\u524d\u7684\u50b7\uff0c\u4ecd\u96b1\u96b1\u5728\u75db\uff0c\u4e26\u6c92\u6709\u771f\u6b63\u7684\u5e73\u5fa9\u3002\u73fe\u5728\uff0c\u518d\u6709 \u50b7\u75db\uff0c\u6211\u6703\u6539\u4ee5\u4e0d\u5e36\u8a55\u5224\u7684\u89c0\u5bdf\uff0c\u5617\u8a66\u53bb\u770b\u6e05\u695a\u767c\u751f\u904e\u7a0b\u8207\u771f\u6b63\u7684\u611f\u53d7\uff0c\u6211\u6df1\u4fe1\uff0c\u89c0\u5bdf\u662f\u6709\u529b\u91cf\u7684\uff0c\u5b83\u6703\u5f15\u9818\u6211\u5011\u89e3\u6c7a\u4e00\u5207\u554f\u984c\u3002 \u4e0d\u5e36\u8a55\u5224\u7684\u89c0\u5bdf\uff0c\u8aaa\u8d77\u4f86\u5bb9\u6613\uff0c\u505a\u8d77\u4f86\u53ef\u4e0d\u662f\u90a3\u9ebc\u7c21\u55ae\uff0c\u56e0\u70ba\u982d\u8166\u592a\u904e\u5805\u5be6\uff0c\u5f88\u96e3\u64fa\u812b\u5b83\u7684\u638c\u63a7\u3002\u4e8b\u5be6\u4e0a\uff0c\u6211\u89c0\u5bdf\u81ea\u5df1\u4e5f\u6709\u516d\u3001\u4e03\u5e74\u4e86\uff0c\u5e73\u6642\u5e38\u5e38\u63d0\u9192\u81ea\u5df1\u653e \u9b06\uff0c\u96a8\u6642\u89c0\u5bdf\u8eab\u9ad4\u611f\u89ba\u8207\u5fc3\u5ff5\uff0c\u9577\u6b64\u4ee5\u5f80\uff0c\u6f38\u6f38\u990a\u6210\u4e86\u7fd2\u6163\uff0c\u60c5\u7dd2\u8d77\u4f0f\u7a0d\u5fae\u5927\u4e00\u4e9b\uff0c\u5c31\u6703\u81ea\u52d5\u7684\u53bb\u89c0\u5bdf\u5fc3\u5ff5\u3002\u4f46\u662f\uff0c\u4e5f\u5c31\u662f\u9019\u6a23\u4e86\uff0c\u5728\u5fc3\u9748\u6210\u9577\u65b9\u9762\uff0c\u4f3c\u4e4e\u5df2\u5728\u539f\u5730 \u8e0f\u6b65\u4e86\u597d\u9577\u4e00\u6bb5\u6642\u9593\u3002\u8207\u6771\u5317\u8001\u5e2b\u76f8\u8655\u9019\u6bb5\u6642\u9593\uff0c\u6211\u767c\u73fe\u4ed6\u9664\u4e86\u6559\u5c0e\u4fee\u884c\u7684\u9053\u7406\u4e4b\u5916\uff0c\u66f4\u96e3\u80fd\u53ef\u8cb4\u7684\u662f\uff0c\u4ed6\u9084\u6709\u4e00\u5957\u56b4\u8b39\u7684\u4fee\u884c\u65b9\u6cd5\uff0c\u6709\u6b21\u7b2c\u7684\u5f15\u9818\u5927\u5bb6\u4e00\u6b65\u6b65\u5730\u964d \u4f0f\u982d\u8166\uff0c\u6253\u958b\u5fc3\u6249\uff0c\u7522\u751f\u6e05\u660e\u667a\u6167\u3002 \u96e3\u4ee5\u8a00\u55bb\u7684\u78ba\u4fe1 \u6211\u66fe\u96dc\u4e03\u96dc\u516b\u5730\u770b\u904e\u4e00\u4e9b\u63a2\u7a76\u751f\u547d\u3001\u5fc3\u9748\u8207\u4fee\u884c\u65b9\u9762\u7684\u66f8\uff0c\u52a0\u4e0a\u7d93\u5e38\u53c3\u8207\u8b80\u66f8\u6703\u3001\u5ea7\u8ac7\u6703\u7b49\u6d3b\u52d5\uff0c\u54ea\u4e9b\u9053\u7406\u8aaa\u5f97\u901a\uff0c\u54ea\u4e9b\u89c0\u5ff5\u592a\u504f\u9817\uff0c\u5728\u6211\u5fc3\u4e2d\u81ea\u6709\u4e00\u5957\u6aa2\u9a57 \u7684\u539f\u5247\u3002\u4f8b\u5982\uff1a\u662f\u5426\u7d93\u5f97\u8d77\u6642\u9593\u8003\u9a57\uff1f\u662f\u5426\u653e\u8af8\u56db\u6d77\u7686\u6e96\uff1f\u662f\u5426\u4fb7\u9650\u65bc\u67d0\u4e9b\u6846\u67b6\uff1f\u662f\u5426\u6709\u6240\u57f7\u53d6\u3001\u5f37\u8abf\u6240\u6c42\u8207\u6240\u5f97\uff1f\u662f\u5426\u80fd\u5728\u751f\u6d3b\u4e2d\u5be6\u8e10\uff1f\u7b49\u7b49\u3002\u6771\u5317\u8001\u5e2b\u6240\u8ac7\u7684\u9053 \u7406\u8207\u7df4\u7fd2\u65b9\u6cd5\uff0c\u4e0d\u4f46\u8d85\u8d8a\u4e86\u6211\u6240\u6709\u7684\u6aa2\u9a57\u539f\u5247\uff0c\u800c\u4e14\uff0c\u8b93\u6211\u5728\u76f4\u89ba\u4e0a\u7522\u751f\u4e00\u4efd\u96e3\u4ee5\u8a00\u55bb\u7684\u78ba\u4fe1\uff0c\u90a3\u5c31\u662f\u4e86\uff01\u5c24\u5176\u4ed6\u7684\u8a00\u884c\u98a8\u7bc4\uff0c\u4e00\u518d\u8b93\u4eba\u611f\u53d7\u5230\u90a3\u7a2e\u6700\u4e0d\u5e73\u51e1\u7684\u5e73\u51e1\u3002 \u6b64\u6642\u6b64\u523b\uff0c\u6771\u5317\u8001\u5e2b\u8207\u5e2b\u6bcd\u9084\u5728\u53f0\u7063\uff0c\u4f46\u6211\u5fc3\u88e1\u5df2\u7136\u6607\u8d77\u4e00\u9663\u6de1\u6de1\u7684\u96e2\u6101\uff0c\u96d6\u7136\u660e\u5929\u9084\u6703\u548c\u4ed6\u5011\u898b\u9762\u3002\u9019\u6bb5\u6642\u9593\u5c0d\u6211\u800c\u8a00\uff0c\u6709\u4e00\u7a2e\u8fd1\u4e4e\u300c\u671d\u805e\u9053\uff0c\u5915\u6b7b\u53ef\u77e3\uff01\u300d\u7684\u5fc3\u60c5\uff0c\u53d7\u76ca\u826f\u591a\u8207\u8877\u5fc3\u611f\u8b1d\u7b49\u6587\u8a5e\uff0c\u5747\u7121\u6cd5\u5f62\u5bb9\u5167\u5fc3\u7684\u611f\u53d7\uff0c\u8b39\u4ee5\u6b64\u6587\u9298\u8a18\u3002\u540c\u6642\uff0c\u6211\u6703\u9806\u5f9e\u90a3\u4efd\u78ba\u4fe1\uff0c\u5728\u5fc3\u7530\u57cb\u4e0b\u4e00\u7c92\u91d1\u525b\u89c0\u5bdf\u7684\u7a2e\u7c7d\uff0c\u76fc\u80fd\u900f\u904e\u89c0\u5bdf\u3001 \u89c0\u5bdf\u3001\u518d\u89c0\u5bdf\uff0c\u4e0d\u8ca0\u6771\u5317\u8001\u5e2b\u5fc3\u610f\u3002<\/p>\n","protected":false},"author":1,"featured_media":0,"comment_status":"closed","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ngg_post_thumbnail":0,"_links_to":"","_links_to_target":""},"categories":[6],"tags":[],"_links":{"self":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/407"}],"collection":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/types\/