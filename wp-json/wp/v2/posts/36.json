67a\u6167\u4ea6\u4e0d\u53ef\u80fd\u4e0d\u5305\u62ec\u611a\u7661\uff0c\u5169\u8005\u662f\u76f8\u4e92\u76f8\u4f9d\u800c\u5b58\u5728\uff0c\u7f3a\u4e00\u4e0d\u53ef\u3002\u82e5\u6b32\u65bc\u667a\u6167\u8207\u611a\u7661\u4e8c\u8005\u9593\u505a\u51fa\u4efb\u4f55\u667a\u6167\u7684\u9078\u64c7\uff0c\u90fd\u7121\u975e\u662f\u982d\u8166\u611a\u7661\u7684\u904a\u6232\u800c\u5df2\u3002<\/p>\n<p>\u751a\u6df1\u667a\u6167\u8207\u5206\u5225\u667a\u6167\u7684\u4e0d\u540c\u662f\u751a\u6df1\u667a\u6167\u4e2d\u6c92\u6709\u5206\u5225\u3002\u56e0\u5176\u6c92\u6709\u5206\u5225\uff0c\u6240\u4ee5\u6c92\u6709\u5c0d\u7acb\uff0c\u4ea6\u5373\u6c92\u6709\u4e0d\u53ef\u907f\u514d\u7684\u8ca0\u9762\u4f5c\u7528\u3002\u4e16\u9593\u5206\u5225\u667a\u6167\u662f\u4f9d\u982d\u8166\u7684\u4e0d\u65b7\u5206\u5225\u800c\u5b58\u5728\uff0c\u800c\u751a\u6df1\u667a\u6167\u5247\u662f\u8d85\u8d8a\u982d\u8166\u7684\u4e00\u5207\u5206\u5225\u3002\u56e0\u6b64\u53ef\u4ee5\u770b\u51fa\uff0c\u5206\u5225\u667a\u6167\u8981\u8f9b\u52e4\u5730\u52d5\u7528\u982d\u8166\uff0c\u800c\u751a\u6df1\u667a\u6167\u5247\u662f\u4e0d\u7528\u982d\u8166\u7684\u8f15\u9b06\u72c0\u614b\u3002<\/p>\n<p>\u4eba\u5011\u5e38\u5e38\u8aa4\u8a8d\u70ba\u982d\u8166\u662f\u8d8a\u7528\u8d8a\u8070\u660e\uff0c\u82e5\u4e0d\u7528\u982d\u8166\u5c31\u6c92\u667a\u6167\u4e86\u3002\u5176\u5be6\u6240\u8b02\u4e0d\u7528\u52d5\u982d\u8166\u53ea\u662f\u4e0d\u52d5\u7528\u76f8\u5c0d\u7684\u5206\u5225\u667a\u6167\uff0c\u6b63\u56e0\u70ba\u8d85\u8d8a\u4e86\u76f8\u5c0d\u7684\u667a\u6167\uff0c\u624d\u555f\u52d5\u4e86\u4e0d\u7528\u982d\u8166\u7684\u751a\u6df1\u667a\u6167\u3002\u4eba\u985e\u7684\u982d\u8166\u53ea\u662f\u751a\u6df1\u667a\u6167\u7684\u5de5\u5177\u800c\u5df2\u3002<\/p>\n<p>\u4eba\u985e\u7531\u65bc\u4e0d\u80fd\u555f\u7528\u672c\u6709\u7684\u751a\u6df1\u667a\u6167\uff0c\u800c\u8b93\u982d\u8166\u5192\u5145\u70ba\u4e3b\u4eba\uff0c\u5192\u5145\u4e3b\u4eba\u7684\u982d\u8166\u63a9\u84cb\u4e86\u4eba\u5011\u5167\u5728\u672c\u81ea\u5177\u8db3\u7684\u751a\u6df1\u667a\u6167\u3002\u7576\u4e00\u500b\u4eba\u958b\u59cb\u4e86\u89e3\u81ea\u5df1\u982d\u8166\u7684\u77db\u76fe\u6027\u8207\u4e0d\u53ef\u9760\u6027\u4e4b\u5f8c\uff0c\u4e00\u5b9a\u6703\u7a4d\u6975\u5730\u5c0b\u627e\u771f\u5be6\u7684\u751a\u6df1\u667a\u6167\u3002<\/p>\n<p>\u751a\u6df1\u667a\u6167\u662f\u4e00\u500b\u6e05\u695a\u660e\u767d\u4e4b\u4eba\uff0c\u5728\u6d1e\u5bdf\u4e86\u76f8\u5c0d\u667a\u6167\u7684\u4e0d\u771f\u5be6\u6027\u4e4b\u5f8c\uff0c\u7e7c\u800c\u89c0\u5bdf\u767c\u73fe\u4e86\u5167\u5fc3\u6df1\u8655\u6c38\u4e0d\u8b8a\u7570\u7684\u5167\u5728\u5149\u660e\uff0c\u540c\u6642\u53c8\u767c\u73fe\u9019\u7a2e\u5149\u660e\u662f\u842c\u4e8b\u842c\u7269\u7684\u672c\u8cea\uff0c\u842c\u4e8b\u842c\u7269\u6709\u6b64\u5149\u660e\u5373\u70ba\u751f\uff0c\u5931\u6b64\u5149\u660e\u5373\u70ba\u6b7b\u3002\u6b64\u5167\u5728\u7684\u5149\u660e\u5275\u9020\u4e00\u5207\u842c\u7269\uff0c\u537b\u4e0d\u898b\u5176\u6709\u6240\u4f5c\u70ba\u3002\u5167\u5728\u5149\u660e\u751f\u6a5f\u84ec\u52c3\u537b\u4e0d\u898b\u5176\u6709\u6240\u52d5\u3002\u5167\u5728\u5149\u660e\u6709\u7121\u9650\u5999\u529b\u537b\u4e0d\u898b\u5176\u6709\u6240\u80fd\u3002\u5167\u5728\u5149\u660e\u662f\u4e00\u5207\u4e4b\u59cb\u537b\u4e0d\u898b\u5176\u70ba\u4e3b\u3002<\/p>\n<p><a href=\"http:\/\/www.is-zen.org\/publication\/pub_index.asp?dfn=GMZX072_index\" target=\"_blank\">\u6458\u9304\u81ea \u5149\u660e\u53e2\u66f8 \u751a\u6df1\u667a\u6167<\/a> \uff08\u8acb\u9ede\u95b1\uff09<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u751a\u6df1\u667a\u6167\u8207\u5206\u5225\u667a\u6167\u7684\u4e0d\u540c\u662f\u751a\u6df1\u667a\u6167\u4e2d\u6c92\u6709\u5206\u5225\u3002\u56e0\u5176\u6c92\u6709\u5206\u5225\uff0c\u6240\u4ee5\u6c92\u6709\u5c0d\u7acb\uff0c\u4ea6\u5373\u6c92\u6709\u4e0d\u53ef\u907f\u514d\u7684\u8ca0\u9762\u4f5c\u7528\u3002\u4e16\u9593\u5206\u5225\u667a\u6167\u662f\u4f9d\u982d\u8166\u7684\u4e0d\u65b7\u5206\u5225\u800c\u5b58\u5728\uff0c\u800c\u751a\u6df1\u667a\u6167\u5247\u662f\u8d85\u8d8a\u982d\u8166\u7684\u4e00\u5207\u5206\u5225\u300