{"id":184,"date":"2004-11-14T18:37:45","date_gmt":"2004-11-15T00:37:45","guid":{"rendered":"http:\/\/www.is-zen.org\/tc\/?p=184"},"modified":"2010-02-23T19:52:23","modified_gmt":"2010-02-24T01:52:23","slug":"keepon","status":"publish","type":"post","link":"http:\/\/www.is-zen.org\/tc\/2004\/keepon\/","title":{"rendered":"\u4e0d\u65b7\u5730\u770b\u8207\u63a5\u53d7"},"content":{"rendered":"<p>\u4f5c\u8005\uff1a\u8377\u5149<\/p>\n<p>\u8d70\u8def\uff0c\u5c0d\u6211\u800c\u8a00\uff0c\u662f\u500b\u4e0d\u65b7\u5730\u770b\u5230\u81ea\u5df1\u548c\u63a5\u53d7\u81ea\u5df1\u7684\u904e\u7a0b\u2026<\/p>\n<p>\u7b2c\u4e00\u6b21\u5c07\u89ba\u77e5\u653e\u5728\u8173\u5e95\u958b\u59cb\u8d70\u8def\u6642\uff0c\u6211\u5f88\u9a5a\u8a1d\u5730\u767c\u73fe\uff0d\u6211\u8b8a\u5f97\u4e0d\u592a\u6703\u8d70\u8def\u4e86\uff0c\u6b6a\u6b6a\u5012\u5012\uff0c\u7ad9\u4e0d\u592a\u7a69(\u9084\u6709\u4eba\u8dcc\u5012)\u3002\u6240\u4ee5\uff0c\u8acb\u5225\u5148\u5165\u70ba\u4e3b\u5730\u8a8d\u70ba\uff1a\u8d70\u8def\uff01\u8ab0\u4e0d\u6703\u554a\uff1f\uff01<\/p>\n<p>\u800c\u6211\uff0c\u4e5f\u4e00\u76f4\u662f\u500b\u5f88\u60f3\u8981\u900f\u904e\u4fee\u884c\uff0c\u628a\u81ea\u5df1\u8b8a\u5f97\u66f4\u597d\u7684\u4eba\u3002\u9019\u500b\u6e34\u671b\u5f88\u6df1\uff0c\u5b83\u5e38\u5e38\u548c\u60f3\u6210\u9053\u7684\u6e34\u671b\u6df7\u6210\u4e00\u5718\uff0c\u5206\u4e0d\u6e05\u8ab0\u5047\u8ab0\u771f\u3001\u8ab0\u591a\u8ab0\u5c11\u3002\u7136\u800c\uff0c\u6e34\u671b\u5c31\u662f\u6709\u6240\u6c42\uff0c\u5c31\u662f\u6709\u6240\u57f7\u8457\uff0c\u9019\u6703\u5f62\u6210\u4fee\u884c\u4e0a\u7684\u969c\u7919\u3002\u6211\u5e38\u5e38\u50cf\u5c0f\u72d7\u4f3c\u5730\u8ffd\u8457\u81ea\u5df1\u5c3e\u5df4\uff0c\u8d8a\u662f\u52aa\u529b\u5730\u8ffd\uff0c\u5c31\u8d8a\u96e2\u8d8a\u9060\uff0c\u8d8a\u4e0d\u5f97\u6cd5\u2026\u3002\u5beb\u5230\u9019\u88e1\uff0c\u6211\u7684\u773c\u6dda\u5fcd\u4e0d\u4f4f\u6d41\u4e0b\u4f86\u3002<\/p>\n<p>\u5728\u8d70\u8def\u4e2d\uff0c\u6211\u770b\u5230\u81ea\u5df1\u6240\u6709\u5728\u751f\u6d3b\u4e2d\u7684\u559c\u3001\u6012\u3001\u54c0\u3001\u6a02\u53ca\u5f85\u4eba\u8655\u4e8b\u7684\u751f\u547d\u614b\u5ea6\u3001\u7fd2\u6027\u3001\u6a21\u5f0f\uff0c\u90fd\u5b8c\u5168\u6fc3\u7e2e\u5728\u300c\u8d70\u8def\u300d\u9019\u4ef6\u4e8b\u4e2d\uff1a\u751f\u6d3b\u4e2d\u7684\u6211\u672c\u4f86\u5c31\u5f88\u5bb9\u6613\u7dca\u5f35\uff0c\u5c0d\u653e\u9b06\u9019\u4ef6\u4e8b\u5df2\u7d93\u5f88\u964c\u751f\u4e86\uff0c\u7136\u800c\u56e0\u70ba\u5f88\u60f3\u8b8a\u597d\uff0c\u6240\u4ee5\u5f88\u300c\u8a8d\u771f\u300d\u5730\u8d70\u8def\uff0c\u53cd\u800c\u8b93\u81ea\u5df1\u66f4\u7dca\u5f35\uff1b\u53c8\u56e0\u70ba\u300c\u60f3\u300d\u628a\u8def\u8d70\u7684\u5f88\u597d\u3001\u5f88\u89ba\u77e5\uff0c\u6240\u4ee5\u7528\u5e7b\u60f3\u5728\u8d70\u8def\uff0c\u800c\u4e0d\u662f\u5be6\u5be6\u5728\u5728\u5730\u628a\u89ba\u77e5\u62c9\u56de\u5230\u8173\u5e95\uff1b\u73fe\u5be6\u751f\u6d3b\u4e2d\uff0c\u6211\u5e38\u5e38\u7fa8\u6155\u5225\u4eba\uff0c\u4e0d\u662f\u77bb\u524d\u5c31\u662f\u9867\u5f8c\uff0c\u6240\u4ee5\u4e00\u807d\u5230\u540c\u4fee\u8d70\u8def\u8d70\u51fa\u5f88\u6b8a\u52dd\u7684\u72c0\u614b\uff0c\u60c5\u4e0d\u81ea\u7981\u5730\u81ea\u6211\u6697\u793a\u9810\u8a2d\uff1a\u6211\u662f\u4e0d\u662f\u4e5f\u53ef\u4ee5\u5982\u6b64\u554a\uff1f\u8d70\u8def\u6642\uff0c\u5076\u723e\u4e4d\u73fe\u7684\u5be7\u975c\u7247\u523b\uff0c\u53c8\u5f88\u671f\u5f85\u5b83\u518d\u6b21\u51fa\u73fe\uff0c\u5373\u4f7f\u77e5\u9053\u61c9\u8a72\u7121\u6240\u6c42\u2026<\/p>\n<p>\u770b\u5230\u5167\u5728\u9019\u4e9b\u4e94\u82b1\u516b\u9580\u7684\u767c\u751f\uff0c\u5c0d\u6211\u4f86\u8aaa\u4e26\u4e0d\u96e3\uff0c\u6700\u96e3\u7684\u662f\uff0c\u770b\u5230\u4e4b\u5f8c\u7684\u63a5\u53d7\u3002\u66f4\u8cbc\u5207\u7684\u8aaa\u6cd5\u61c9\u8a72\u662f\uff1a\u63a5\u53d7\u81ea\u5df1\u7684\u300c\u4e0d\u63a5\u53d7\u300d\u3002(\u6c92\u6709\u592a\u96e3\u61c2\u5427)<\/p>\n<p>\u7531\u65bc\u4e00\u518d\u5730\u7ffb\u652a\u8207\u4e00\u518d\u5730\u770b\u5230\uff0c\u4ee5\u53ca\u4e00\u76f4\u6301\u7e8c\u8d70\u8def\uff0c\u6211\u9577\u5e74\u4f86\u7262\u4e0d\u53ef\u7834\u7684\u6a21\u5f0f\uff0c\u958b\u59cb\u6709\u4e86\u9b06\u52d5\u3002\u9019\u5c0d\u6211\u4f86\u8aaa\uff0c\u771f\u662f\u4e00\u7dda\u66d9\u5149\u3002\u6211\u958b\u59cb\u8f03\u61c2\u5f97\u653e\u9b06\uff0c\u9047\u5230\u4e8b\u60c5\u4e0d\u518d\u7aae\u7a76\u5206\u6790\uff0c\u5c31\u53ea\u662f\u56de\u5230\u89ba\u77e5\uff0c\u5c31\u7b97\u5206\u6790\u4e86\uff0c\u4e5f\u4e0d\u8b74\u8cac\u81ea\u5df1\uff0c\u5c31\u7b97\u8b74\u8cac\u81ea\u5df1\u4e86\uff0c\u4e5f\u53ea\u662f\u99ac\u4e0a\u56de\u4f86\u800c\u5df2\u3002<\/p>\n<p>\u6211\u7684\u5fc3\u4e5f\u4e0d\u6703\u90a3\u9ebc\u5bb9\u6613\u614c\u4e82\u7121\u63aa\uff0c\u5c31\u7b97\u6709\uff0c\u4e5f\u6bd4\u4ee5\u5f80\u56de\u5fa9\u7684\u5feb\u5f97\u591a\uff0c\u7576\u9047\u5230\u56f0\u96e3\u6642\uff0c\u5df2\u7d93\u6703\u7528\u5be7\u975c\u4ee3\u66ff\u982d\u8166\u7684\u5929\u99ac\u884c\u7a7a\u822c\u5730\u4e82\u60f3\u4e00\u901a\uff0c\u6162\u6162\u8f03\u80fd\u548c\u81ea\u5df1\u76f8\u8655\uff0c\u56de\u5230\u81ea\u5df1\u7684\u4e2d\u5fc3\u3002<\/p>\n<p>\u9019\u4e9b\uff0c\u5982\u679c\u4e0d\u662f\u56e0\u70ba\u5728\u8d70\u8def\u4e2d\u57f9\u990a\u7684\u57fa\u790e\uff0c\u662f\u5f88\u96e3\u8fa6\u5230\u7684\u3002\u56e0\u70ba\u7fd2\u6027\u662f\u975e\u5e38\u5f37\u5927\u7684\u602a\u7269\uff0c\u4f60\u8d8a\u8ddf\u5b83\u7e8f\u9b25\uff0c\u5c31\u8d8a\u6c92\u5b8c\u6c92\u4e86\uff0c\u4f60\u4e0d\u7406\u5b83\uff0c\u5b83\u624d\u6703\u6f38\u6f38\u5730\u6c92\u6232\u5531\u4e86\u3002\u9019\u500b\u300c\u4e0d\u7406\u300d\u7684\u80fd\u529b\uff0c\u5c31\u53ea\u80fd\u9760\u300c\u8d70\u8def\u300d\u4e2d\u4e0d\u65b7\u5730\u56de\u5230\u89ba\u77e5\u4f86\u7d2f\u7a4d\u3002<\/p>\n<p>\u662f\u7684\uff0c\u5929\u5e95\u4e0b\u6c92\u6709\u6bd4\u9019\u518d\u7c21\u55ae\u7684\u4e8b\u4e86\uff0c\u4f60\u5c31\u53ea\u662f\u56de\u5230\u89ba\u77e5\u800c\u5df2\u3002\u6f38\u6f38\u5730\uff0c\u6211\u5df2\u7d93\u958b\u59cb\u80fd\u9ad4\u5617\u9019\u4ef6\u7c21\u55ae\u4e8b\u60c5\u88e1\u9762\u7684\u7121\u7aae\u7f8e\u597d\u3002\u6c92\u6709\u4ec0\u9ebc\u5927\u4e0d\u4e86\uff0c\u5c31\u53ea\u662f\u300c\u56de\u4f86\u300d\u800c\u5df2\uff01<\/p>\n<p>\u6211\u7684\u5343\u5e74\u5927\u982d\uff08\u80e1\u601d\u4e82\u60f3+\u8139\u3001\u75db\u3001\u60b6\u3001\u5835\u3001\u91cd\uff09\u662f\u56e0\u70ba\u8d70\u8def\uff0c\u624d\u958b\u59cb\u4eab\u53d7\u5230\u8f15\u76c8\u3001\u653e\u9b06\u3001\u4f11\u606f\u7684\u6ecb\u5473\u3002\u6211\u8001\u611b\u5411\u5916\u9700\u7d22\u7684\u5331\u4e4f\u611f\uff0c\u662f\u56e0\u70ba\u8d70\u8def\uff0c\u624d\u6162\u6162\u5730\u77e5\u9053\uff1a\u53ea\u6709\u81ea\u5df1\u624d\u80fd\u76c8\u6eff\u81ea\u5df1\uff1b\u6211\u8001\u662f\u7dca\u7e43\u7684\u60c5\u7dd2\uff0c\u662f\u56e0\u70ba\u8d70\u8def\uff0c\u5167\u5728\u958b\u59cb\u50cf\u4e00\u9996\u97f3\u6a02\u6f14\u594f\u6d41\u52d5\u8d77\u4f86\uff1b\u6211\u8001\u611b\u6d88\u6975\u7684\u81ea\u6211\u6697\u793a\uff0c\u662f\u56e0\u70ba\u8d70\u8def\uff0c\u77e5\u9053\u5b83\u6c92\u4ec0\u9ebc\u53ef\u6015\uff0c\u4e0d\u7406\u5c31\u884c\u4e86\uff01<\/p>\n<p>\u5c31\u9019\u6a23\uff0c\u7121\u610f\u4e2d\uff0c\u4e00\u4e9b\u8f03\u7d30\u81a9\u7684\u611f\u53d7\u958b\u59cb\u6d6e\u73fe\uff0c\u539f\u672c\u4e00\u76f4\u5922\u5bd0\u4ee5\u6c42\u7684\u73fe\u8c61\u4e5f\u767c\u751f\u4e86\u3002\u563f\u563f\uff01\u4f46\u662f\u73fe\u5728\u7684\u6211\uff0c\u5df2\u7d93\u5b78\u4e56\u4e86\uff0c\u5c31\u53ea\u662f\u300c\u770b\u300d\u8457\u800c\u5df2\uff0c\u9023\u300c\u63a5\u4e0d\u63a5\u53d7\u300d\u90fd\u4e0d\u9700\u8981\u4e86\u3002<\/p>\n<p>\u6211\u8d8a\u4f86\u8d8a\u559c\u6b61\u8d70\u8def\uff0c\u4e5f\u8d8a\u4f86\u8d8a\u80fd\u4eab\u53d7\u8d70\u8def\u4e86\u3002\u96d6\u7136\uff0c\u6f5b\u610f\u8b58\u88e1\u9084\u662f\u6709\u6240\u6c42\uff0c\u4f46\u6211\u624d\u4e0d\u7ba1\u4f60\u4e86\u52d2\u3002\u5c31\u53ea\u662f\u300c\u770b\u300d\u5c31\u5c0d\u4e86\uff01\u300c\u56de\u4f86\u300d\u5c31\u5c0d\u4e86\u3002\u982d\u8166\uff0c\u4e0d\u597d\u610f\u601d\u5594\uff01\u6211\u4e0d\u73a9\u4e86\uff01<\/p>\n<p>\u771f\u7684\uff0c\u5728\u4f60\u9084\u6c92\u6709\u5617\u8a66\u7528\u89ba\u77e5\u8d70\u8def\u524d\uff0c\u5343\u842c\u5225\u5148\u5165\u70ba\u4e3b\u5730\u8a8d\u70ba\uff1a\u8d70\u8def\uff01\u8ab0\u4e0d\u6703\u554a\uff1f\uff01<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u7531\u65bc\u4e00\u518d\u5730\u7ffb\u652a\u8207\u4e00\u518d\u5730\u770b\u5230\uff0c\u4ee5\u53ca\u4e00\u76f4\u6301\u7e8c\u8d70\u8def\uff0c\u6211\u9577\u5e74\u4f86\u7262\u4e0d\u53ef\u7834\u7684\u6a21\u5f0f\uff0c\u958b\u59cb\u6709\u4e86\u9b06\u52d5\u3002\u9019\u5c0d\u6211\u4f86\u8aaa\uff0c\u771f\u662f\u4e00\u7dda\u66d9\u5149\u3002\u6211\u958b\u59cb\u8f03\u61c2\u5f97\u653e\u9b06\uff0c\u9047\u5230\u4e8b\u60c5\u4e0d\u518d\u7aae\u7a76\u5206\u6790\uff0c\u5c31\u53ea\u662f\u56de\u5230\u89ba\u77e5\uff0c\u5c31\u7b97\u5206\u6790\u4e86\uff0c\u4e5f\u4e0d\u8b74\u8cac\u81ea\u5df1\uff0c\u5c31\u7b97\u8b74\u8cac\u81ea\u5df1\u4e86\uff0c\u4e5f\u53ea\u662f\u99ac\u4e0a\u56de\u4f86\u800c\u5df2\u3002<\/p>\n","protected":false},"author":1,"featured_media":0,"comment_status":"closed","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ngg_post_thumbnail":0,"_links_to":"","_links_to_target":""},"categories":[14],"tags":[],"_links":{"self":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/184"}],"collection":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/comments?post=184"}],"version-history":[{"count":7,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/184\/revisions"}],"predecessor-version":[{"id":189,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/184\/revisions\/189"}],"wp:attachment":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/media?parent=184"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/categories?post=184"},{"taxonomy":"post_tag","embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v