{"id":293,"date":"2005-07-17T22:08:45","date_gmt":"2005-07-18T04:08:45","guid":{"rendered":"http:\/\/www.is-zen.org\/tc\/?p=293"},"modified":"2010-02-23T22:11:33","modified_gmt":"2010-02-24T04:11:33","slug":"findout","status":"publish","type":"post","link":"http:\/\/www.is-zen.org\/tc\/2005\/findout\/","title":{"rendered":"\u6211\u627e\u5230\u4e86"},"content":{"rendered":"<p>\u4f5c\u8005\uff1a\u53eb\u6211\u7b2c\u4e00\u540d<\/p>\n<p>\u81ea\u5df1\u5728\u4eba\u751f\u7684\u8def\u4e0a\u5c0b\u8993\u597d\u4e45\uff0c\u4f60\u554f\u6211\u7a76\u7adf\u5728\u627e\u4ec0\u9ebc\uff1f\u6211\u53ea\u662f\u60f3\u77e5\u9053\u751f\u547d\u7684\u610f\u7fa9\uff01\u4eba\u751f\u5230\u5e95\u662f\u4f55\u76ee\u7684\uff1f\u83ab\u540d\u7684\u751f\u3001\u83ab\u540d\u7684\u6b7b\uff0c\u8ddf\u4e00\u4e9b\u4eba\u7522\u751f\u4e9b\u95dc\u806f\uff0c\u4e0a\u73ed\u4e0b\u73ed\u990a\u5bb6\u6d3b\u53e3\uff0c\u7537\u5973\u6709\u60c5\u76f8\u5b88\u7121\u60c5\u5206\u624b\uff0c\u8f9b\u82e6\u8cfa\u9322\u5230\u9000\u4f11\u8001\u6b7b\uff0c\u4e00\u8f29\u5b50\u5728\u4e00\u500b\u56fa\u5b9a\u7684\u6a21\u5f0f\u4e2d\u5faa\u74b0\uff0c\u544a\u8a34\u6211\u4eba\u751f\u5c31\u662f\u5982\u6b64\u55ce\uff1f\u662f\u7684\uff0c\u653e\u773c\u671b\u53bb\u773e\u7686\u5982\u6b64\u3002<\/p>\n<p>\u5f9e\u5c0f\u88ab\u4e00\u7a2e\u82e6\u60b6\u7684\u6c1b\u570d\u7c60\u7f69\uff0c\u537b\u8868\u73fe\u51fa\u5341\u5206\u6a02\u89c0\u7684\u5916\u76f8\uff0c\u5167\u5916\u7684\u77db\u76fe\u4f7f\u81ea\u5df1\u6df1\u611f\u7121\u529b\uff0c\u975e\u5e38\u53ad\u5026\u751f\u547d\u7684\u865b\u5047\u6a21\u5f0f\uff0c\u4fbf\u958b\u59cb\u7a4d\u6975\u627e\u5c0b\u751f\u547d\u771f\u8ae6\u3002\u53db\u9006\u671f\u7684\u6840\u9a41\u4e0d\u99b4\uff0c\u8ffd\u5c0b\u5e6b\u773e\u529b\u91cf\uff0c\u537b\u767c\u73fe\u5167\u5fc3\u4e0d\u5920\u6b98\u5fcd\uff1b\u559c\u597d\u8868\u6f14\u66fe\u7a4d\u6975\u821e\u53f0\u6f14\u51fa\uff0c\u537b\u767c\u73fe\u6f14\u51fa\u5f8c\u7684\u843d\u5dee\u96e3\u4ee5\u627f\u53d7\uff1b\u521d\u5690\u611b\u60c5\u7684\u751c\u871c\u6ecb\u5473\uff0c\u537b\u56e0\u7a2e\u7a2e\u5916\u5728\u58d3\u529b\u800c\u6210\u70ba\u8ca0\u64d4\uff0c\u5206\u624b\u7684\u5b64\u5bc2\u5be6\u96e3\u63a5\u53d7\uff1b\u6700\u5f8c\u627e\u5230\u4fee\u884c\u4e4b\u8def\u3002<\/p>\n<p>\u7576\u521d\u63a5\u53d7\u4fee\u884c\u89c0\u5ff5\uff0c\u4f86\u81ea\u4e00\u4f4d\u6c23\u529f\u517c\u5b97\u6559\u8001\u5e2b\u3002\u56e0\u70ba\u7df4\u529f\u7684\u95dc\u4fc2\u5167\u5728\u7684\u4e0d\u5e73\u8861\u5f97\u5230\u7ba1\u9053\u5ba3\u6d29\uff0c\u52a0\u4e0a\u4e00\u4e9b\u5b97\u6559\u89c0\u5ff5\u7684\u6d17\u79ae\uff0c\u5167\u5728\u4f3c\u4e4e\u627e\u5230\u4e00\u7a2e\u5b89\u5b9a\u7684\u611f\u89ba\u3002\u4e0d\u904e\u6642\u9593\u7e3d\u662f\u6b98\u9177\u7684\u8003\u9a57\uff0c\u865f\u7a31\u300c\u4fee\u884c\u7684\u4eba\u300d\uff0c\u7df4\u529f\u80fd\u51fa\u73fe\u4e00\u4e9b\u72c0\u614b\uff0c\u4f46\u662f\u72c0\u614b\u4e26\u4e0d\u80fd\u7dad\u6301\u592a\u4e45\uff0c\u4fbf\u6301\u7e8c\u7df4\u529f\u8ffd\u6c42\u72c0\u614b\uff0c\u537b\u7121\u6cd5\u518d\u9054\u5230\u66fe\u7d93\u64c1\u6709\u7684\u9ad8\u5cf0\uff0c\u6240\u4ee5\u5167\u5728\u7684\u5931\u843d\u6084\u7136\u51fa\u73fe\u3002\u8001\u5e2b\u96d6\u53e3\u82e5\u61f8\u6cb3\u7684\u8a34\u8aaa\u4fee\u884c\u4fee\u9053\uff0c\u4f46\u4e3b\u8ef8\u4e0d\u65b7\u6539\u8b8a\u4ee4\u4eba\u7121\u6240\u9069\u5f9e\uff0c\u52a0\u4e0a\u8ca1\u8272\u4e0a\u7684\u7cfe\u845b\uff0c\u4ee4\u6211\u9eef\u7136\u7684\u9060\u96e2\u4fee\u884c\u4e4b\u8def\u3002<\/p>\n<p>\u627e\u5230\u4e00\u500b\u53ef\u611b\u5973\u4eba\u6253\u7b97\u5e73\u6de1\u5ea6\u904e\u4e00\u751f\uff0c\u4e0d\u518d\u60f3\u6240\u8b02\u7684\u4fee\u884c\u3001\u751f\u547d\u610f\u7fa9\u9019\u4e9b\u81ea\u5c0b\u7169\u60f1\u7684\u554f\u984c\uff0c\u8c48\u77e5\u8001\u5929\u7d66\u4e86\u4e00\u500b\u557c\u7b11\u7686\u975e\u7684\u7d50\u5c40\uff0c\u738b\u5b50\u516c\u4e3b\u6c92\u6709\u5f9e\u6b64\u904e\u8457\u5e78\u798f\u5feb\u6a02\u7684\u65e5\u5b50\uff0c\u537b\u662f\u5973\u4e3b\u89d2\u5f97\u4e86\u4e0d\u6cbb\u4e4b\u75c7\u9999\u6d88\u7389\u6b9e\u3002\u751f\u96e2\u6b7b\u5225\u7684\u75db\u82e6\u3001\u8eab\u9ad4\u75db\u695a\u7684\u6298\u78e8\u3001\u5fc3\u7406\u72c0\u614b\u7121\u6cd5\u8abf\u9069\uff0c\u518d\u4e00\u6b21\u60e1\u72e0\u72e0\u7684\u885d\u64ca\u8457\u4e0d\u80fd\u518d\u627f\u53d7\u7684\u6211\uff0c\u7a76\u7adf\u4eba\u751f\u662f\u8981\u4f5c\u4ec0\u9ebc\uff1f\u544a\u8a34\u6211\uff01<\/p>\n<p>\u65e9\u5728\u9060\u96e2\u4fee\u884c\u7684\u90a3\u6bb5\u65e5\u5b50\uff0c\u4fbf\u6709\u670b\u53cb\u4ecb\u7d39\uff08\u6771\u5317\uff09\u8001\u5e2b\uff0c\u90a3\u6642\u7684\u6211\u807d\u5230\u300c\u8001\u5e2b\u300d\u5c31\u904e\u654f\uff0c\u4e00\u9ede\u8208\u8da3\u4e5f\u6c92\u6709\u3002\u53ef\u662f\u7576\u751c\u871c\u7684\u5169\u4eba\u4e16\u754c\u51fa\u73fe\u5669\u8017\u516d\u795e\u7121\u4e3b\u6642\uff0c\u4e00\u500b\u5076\u7136\u7684\u6a5f\u6703\u898b\u5230\u8001\u5e2b\uff0c\u525b\u898b\u9762\u6642\u53ea\u89ba\u5f97\u4ed6\u4e26\u4e0d\u7279\u51fa\uff0c\u751a\u81f3\u5e73\u51e1\u81f3\u6975\uff0c\u4e00\u9ede\u5305\u88dd\u90fd\u6c92\u6709\u3002\u4f46\u8001\u5e2b\u7684\u8ac7\u8a71\u5167\u5bb9\u662f\u8a00\u4e4b\u6709\u7269\u3001\u7d2e\u5be6\u4e26\u5177\u7a7f\u900f\u6027\u3002\u5c31\u5728\u8ac7\u8a71\u9593\u4ed6\u7a81\u7136\u8aaa\u5176\u7acb\u8ad6\u7686\u4f9d\u64da\u4f5b\u7d93\uff0c\u4fbf\u8208\u8d77\u5538\u4e00\u6bb5\u7d93\u6587\u7d66\u5927\u5bb6\u807d\u3002\u90a3\u6642\u6211\u5750\u5728\u5f8c\u9762\uff0c\u8eab\u9ad4\u611f\u5230\u5de8\u5927\u7684\u6643\u52d5\uff0c\u773c\u6dda\u64b2\u7c0c\u7c0c\u4e0d\u505c\u7684\u6389\u843d\uff0c\u5982\u6b64\u83ab\u540d\u7684\u767c\u751f\u4ee4\u6211\u76f8\u7576\u9707\u64bc\u3002\u300c\u9019\u662f\u2026\uff1f\u53ea\u662f\u5538\u500b\u7d93\uff01\u767c\u751f\u4ec0\u9ebc\u4e8b\u5566\uff1f\u300d\u6211\u8209\u8d77\u624b\u95e1\u8ff0\u525b\u624d\u7684\u60c5\u5f62\uff0c\u8001\u5e2b\u8f15\u63cf\u6de1\u5beb\u7684\u56de\u7b54\uff1a\u300c\u6b63\u5e38\uff01\u5f88\u591a\u4eba\u90fd\u6703\u9019\u6a23\uff0c\u8868\u793a\u4f60\u8ddf\u4f5b\u7d93\u76f8\u61c9\u3002\u300d\u624d\u653e\u5fc3\u81ea\u5df1\u6c92\u6709\u7cbe\u795e\u6563\u4e82\u3002\u8001\u5e2b\u53c8\u8aaa\u6211\u518d\u5538\u4e00\u6bb5\u7d93\u6587\u8b93\u4f60\u5011\u4e86\u89e3\uff0c\u7d50\u679c\u76f8\u540c\u72c0\u614b\u518d\u5ea6\u767c\u751f\u3002\u90a3\u5929\u56de\u5bb6\u9a0e\u8457\u6469\u6258\u8eca\uff0c\u5fc3\u4e2d\u611f\u5230\u5145\u5be6\u5be7\u975c\u3002\u5fc3\u7d93\u6700\u5f8c\u7684\u5492\u6587\u300c\u63ed\u8ae6\u63ed\u8ae6\u2026\u2026\u300d\u4e0d\u505c\u5730\u5728\u5fc3\u88e1\u8ff4\u7e5e\uff0c\u5230\u5bb6\u5f8c\u544a\u8a34\u592a\u592a\u300c\u6211\u627e\u5230\u4e86\uff01\u300d<\/p>\n<p>\u8001\u5e2b\u7684\u6559\u5c0e\u5341\u5206\u7c21\u55ae\u6a38\u8cea\uff0c\u5c31\u662f\u6559\u4f60\u5f9e\u8d70\u8def\u958b\u59cb\u89c0\u5bdf\u81ea\u5df1\u3002\u6240\u4ee5\u4e00\u958b\u59cb\u53eb\u5927\u5bb6\u300c\u8b66\u89ba\u300d\u3001\u300c\u770b\u8173\u300d\u3001\u300c\u4fdd\u6301\u89ba\u77e5\u300d\u7b49\uff0c\u90fd\u662f\u8981\u5927\u5925\u56de\u5230\u8173\u5e95\u7684\u611f\u89ba\u3002\u8aaa\u771f\u7684\uff0c\u7df4\u7fd2\u6642\u5e38\u5e38\u4e00\u982d\u9727\u6c34\uff0c\u4e14\u611f\u5230\u76f8\u7576\u5f46\u626d\uff0c\u56e0\u70ba\u6839\u672c\u4e0d\u77e5\u9053\u81ea\u5df1\u5728\u5e79\u5565\uff01\u52a0\u4e0a\u592a\u592a\u75c5\u91cd\u4e5f\u6c92\u6709\u591a\u9918\u6642\u9593\u597d\u597d\u8d70\u8def\uff0c\u6240\u4ee5\u5c0d\u65bc\u8001\u5e2b\u7684\u6559\u5c0e\u4e00\u77e5\u534a\u89e3\u3002\u96a8\u8457\u592a\u592a\u8eab\u9ad4\u6bcf\u6cc1\u6108\u4e0b\uff0c\u6211\u7684\u8eab\u5fc3\u906d\u53d7\u7a7a\u524d\u7684\u75db\u82e6\u3002\u5ffd\u7136\u4e00\u5929\u6211\u544a\u8a34\u81ea\u5df1\u300c\u6211\u4e0d\u60f3\u518d\u75db\u82e6\u4e86\uff01\u300d\u5f9e\u90a3\u5929\u8d77\u96d6\u7136\u7121\u6cd5\u5e38\u8d70\u8def\uff0c\u4f46\u6211\u76e1\u91cf\u628a\u611f\u89ba\u5e36\u56de\u5230\u8173\u5e95\uff0c\u5c31\u662f\u9019\u9ebc\u55ae\u7d14\u7684\u52d5\u4f5c\uff0c\u5b83\u5e6b\u6211\u5ea6\u904e\u592a\u592a\u75c5\u5371\u904e\u4e16\u7684\u75db\u82e6\u3002<\/p>\n<p>\u982d\u8166\u662f\u6211\u5011\u6d6a\u8cbb\u80fd\u91cf\u6700\u591a\u7684\u4e2d\u5fc3\uff0c\u5fc3\u52d5\u662f\u6211\u5011\u6700\u96e3\u63a7\u5236\u7684\u72c0\u6cc1\uff0c\u4f46\u662f\u53ea\u8981\u4f60\u53bb\u8d70\u8d70\u8def\uff0c\u8f15\u9b06\u7684\u5c07\u6ce8\u610f\u529b\u5e36\u56de\u8173\u5e95\uff0c\u4e0d\u5e36\u8981\u6c42\u3001\u4e0d\u52aa\u529b\u3001\u4e0d\u63a7\u5236\uff0c\u53ea\u662f\u4e00\u500b\u611f\u89ba\u8173\u7684\u65b9\u5f0f\uff0c\u7adf\u7136\u80fd\u8f15\u6613\u7684\u964d\u4f0f\u982d\u8166\u5984\u60f3\uff0c\u628a\u7169\u52d5\u4e0d\u5b89\u7684\u5fc3\u5e36\u56de\u4f86\uff0c\u6211\u500b\u4eba\u89ba\u5f97\u9019\u65b9\u6cd5\u592a\u795e\u5947\u4e86\uff01\u4e0d\u53ea\u662f\u5340\u5340\u9019\u9ede\u529f\u6548\uff0c\u5c31\u662f\u9019\u6a23\u8f15\u8f15\u7684\u56de\u5230\u8173\u5e95\uff0c\u89e3\u6c7a\u4e86\u751f\u7406\u7684\u3001\u5fc3\u7406\u7684\u7a2e\u7a2e\u6b32\u6c42\uff0c\u800c\u6211\u4e26\u6c92\u6709\u60f3\u89e3\u6c7a\u4efb\u4f55\u4e8b\u60c5\uff0c\u5b83\u5c31\u662f\u767c\u751f\u4e86\u3002\u66f4\u6709\u8da3\u7684\u662f\u4e00\u4e9b\u6666\u6f80\u96e3\u61c2\u7684\u4f5b\u5b78\u540d\u76f8\uff0c\u5e38\u5e38\u5728\u8d70\u8def\u89ba\u77e5\u7576\u4e2d\u8c41\u7136\u660e\u77ad\uff0c\u73fe\u5728\u95b1\u8b80\u4f5b\u7d93\u5b57\u5b57\u53e5\u53e5\u5747\u9bae\u6d3b\u5730\u5448\u73fe\u5176\u6df1\u610f\uff0c\u9019\u4e00\u5207\u5be6\u5728\u662f\u592a\u5947\u5999\u4e86\u3002<\/p>\n<p>\u518d\u591a\u7684\u63cf\u8ff0\u4e5f\u7121\u6cd5\u771f\u5be6\u5448\u73fe\u6211\u6240\u611f\u53d7\u548c\u7d93\u6b77\uff0c\u53ea\u662f\u8ddf\u5927\u5bb6\u5206\u4eab\u8001\u5e2b\u7684\u6559\u5c0e\u53ca\u81ea\u5df1\u7684\u9ad4\u6703\uff0c\u5e0c\u671b\u5c0d\u5fd7\u5411\u4fee\u884c\u7684\u540c\u4fee\u6709\u6240\u52a9\u76ca\uff0c\u76f8\u4fe1\u8001\u5e2b\u6240\u6559\u7684\u65b9\u6cd5\u800c\u9019\u5167\u5728\u7684\u300c\u4fe1\u300d\u6703\u6709\u529b\u91cf\uff0c\u96a8\u8457\u9019\u500b\u529b\u91cf\u53bb\u5be6\u8e10\u8d70\u8def\uff0c\u6211\u76f8\u4fe1\u6bcf\u4e00\u500b\u4eba\u90fd\u80fd\u627e\u5230\u81ea\u5df1\u8d70\u8def\u7684\u79d8\u5bc6\u3002<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u982d\u8166\u662f\u6211\u5011\u6d6a\u8cbb\u80fd\u91cf\u6700\u591a\u7684\u4e2d\u5fc3\uff0c\u5fc3\u52d5\u662f\u6211\u5011\u6700\u96e3\u63a7\u5236\u7684\u72c0\u6cc1\uff0c\u4f46\u662f\u53ea\u8981\u4f60\u53bb\u8d70\u8d70\u8def\uff0c\u8f15\u9b06\u7684\u5c07\u6ce8\u610f\u529b\u5e36\u56de\u8173\u5e95\uff0c\u4e0d\u5e36\u8981\u6c42\u3001\u4e0d\u52aa\u529b\u3001\u4e0d\u63a7\u5236\uff0c\u53ea\u662f\u4e00\u500b\u611f\u89ba\u8173\u7684\u65b9\u5f0f\uff0c\u7adf\u7136\u80fd\u8f15\u6613\u7684\u964d\u4f0f\u982d\u8166\u5984\u60f3\uff0c\u628a\u7169\u52d5\u4e0d\u5b89\u7684\u5fc3\u5e36\u56de\u4f86\uff0c\u6211\u500b\u4eba\u89ba\u5f97\u9019\u65b9\u6cd5\u592a\u795e\u5947\u4e86\uff01<\/p>\n","protected":false},"author":1,"featured_media":0,"comment_status":"closed","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ngg_post_thumbnail":0,"_links_to":"","_links_to_target":""},"categories":[15],"tags":[],"_links":{"self":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/293"}],"collection":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/comments?post=293"}],"version-history":[{"count":2,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/293\/revisions"}],"predecessor-version":[{"id":295,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/293\/revisions\/295"}],"wp:attachment":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/media?parent=293"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/categories?post=293"},{"taxonomy":"post_tag","embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/tags?post=293"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}