{"id":179,"date":"2004-11-07T18:29:20","date_gmt":"2004-11-08T00:29:20","guid":{"rendered":"http:\/\/www.is-zen.org\/tc\/?p=179"},"modified":"2010-02-23T18:36:27","modified_gmt":"2010-02-24T00:36:27","slug":"onfoot","status":"publish","type":"post","link":"http:\/\/www.is-zen.org\/tc\/2004\/onfoot\/","title":{"rendered":"\u770b\u597d\u5169\u8db3\uff0c\u982d\u8166\u964d\u4f0f"},"content":{"rendered":"<p>\u4f5c\u8005\uff1a\u4e86\u7fa9<\/p>\n<p>\u5728\u5e73\u9806\u7684\u4eba\u751f\u65c5\u9014\u4e0a\u7a81\u7136\u51fa\u73fe\u4e00\u6bb5\u632b\u6298\u56f0\u5384\u6642\u671f\uff0c\u9813\u7136\u5fc3\u4e2d\u7121\u4e3b\uff0c\u9677\u5165\u832b\u832b\u7121\u63aa\uff0c\u4e0d\u77e5\u4f55\u53bb\u4f55\u5f9e\u3002<\/p>\n<p>\u4e8c\u5e74\u524d\u5728\u4e00\u56e0\u7de3\u5de7\u5408\u4e2d\uff0c\u5e2b\u7236\u51fa\u73fe\u4e86\uff0c\u5c0d\u65bc\u5f9e\u4f86\u672a\u63a5\u89f8\u904e\u4f5b\u6cd5\u7684\u6211\uff0c\u5c0d\u4f5b\u7684\u8a8d\u8b58\u53ea\u77e5\u9053\u5bb6\u88e1\u5abd\u5abd\u9022\u5e74\u904e\u7bc0\u7e3d\u6703\u71d2\u9999\u62dc\u4f5b\u7948\u6c42\u5e73\u5b89\uff0c\u66f4\u4e0d\u77e5\u70ba\u4f55\u8981\u4fee\u884c\uff0c\u5982\u4f55\u4fee\u884c\u3002\u5e2b\u7236\u6700\u521d\u7684\u6559\u8aa8\u5c31\u662f\u300c\u4f60\u597d\u597d\u5730\u53bb\u8d70\u8def\u300d\u3002\u8d70\u8def\uff1f!\u5e73\u6642\u4e5f\u5e38\u8d70\u8def\u904b\u52d5\u8e66\u8e66\u8df3\u8df3\uff0c\u600e\u9ebc\u4e5f\u6c92\u6cd5\u628a\u8d70\u8def\u8207\u5b78\u4f5b\u4fee\u884c\u9023\u8cab\u8d77\u4f86\u3002<\/p>\n<p>\u5e78\u597d\uff0c\u6709\u9019\u6279\u591a\u5e74\u8ddf\u8457\u5e2b\u7236\u5b78\u8d70\u8def\u7684\u83ef\u5e9c\u540c\u4fee\u7684\u6307\u5c0e\u8207\u5206\u4eab\uff0c\u591a\u5c11\u4e00\u958b\u59cb\u4e5f\u6478\u5230\u4e00\u9ede\u76ae\u6bdb\uff0c\u4ed6\u5011\u7d66\u6211\u7684\u53e3\u8a23\u662f\u300c\u653e\u8f15\u9b06\u5730\u8d70\u300d\uff0c\u982d\u8166\u6709\u4e86\u96dc\u5ff5\u77e5\u9053\u4e86\uff0c\u5c31\u628a\u6ce8\u610f\u529b\u5e36\u56de\u8173\u5e95\uff0c\u53ca\u300c\u6ce8\u610f\u8eab\u9ad4\u76ae\u819a\u7684\u611f\u89ba\u300d\u5c31\u9019\u6a23\u7528\u9019\u500b\u65b9\u5f0f\u5617\u8a66\u8457\u65b7\u65b7\u7e8c\u7e8c\u5730\u8d70\u4e86\u534a\u5e74\u3002<\/p>\n<p>2003\u5e74\u590f\u5929\uff0c\u5e2b\u7236\u7279\u5730\u70ba\u83ef\u5e9c\u540c\u4fee\u958b\u4e86\u4e00\u5802\u300c\u8209\u8db3\u5411\u4f5b\u73ed\u300d\uff0c\u5728\u5fb3\u5dde\u4f11\u58eb\u9813\u4e8c\u500b\u79ae\u62dc\u7684\u53c3\u79aa\u4e2d\uff0c\u5b78\u7fd2\u8d70\u8def\u89c0\u7167\uff0c\u4e0d\u50c5\u5728\u7406\u4e0a\u6d89\u7375\u8a31\u591a\u4f5b\u7d93\u7684\u771f\u7fa9\uff0c\u884c\u4e0a\u5247\u66f4\u7cbe\u78ba\u5730\u5728\u8d70\u8def\u4e0a\u5be6\u4fee\u3002\u6700\u5f8c\u4e00\u7bc0\u5728\u91d1\u525b\u7d93\u7684\u9707\u64bc\u8499\u85b0\u4e0b\uff0c\u6211\u9813\u609f\u5230\u81ea\u5df1\u5c31\u50cf\u525b\u51fa\u751f\u7684\u5b30\u5152\uff0c\u7d14\u6f54\u7684\u81ea\u6027\u9010\u6f38\u5730\u6210\u9577\uff0c\u50cf\u5c0f\u5b69\u958b\u59cb\u5b78\u8d70\u8def\uff0c\u8e0f\u51fa\u8e63\u8dda\u7684\u7b2c\u4e00\u6b65\uff0c\u671d\u8457\u4f5b\u7684\u5927\u9580\u8d70\u53bb\u3002<\/p>\n<p>\u56de\u4f86\u4e4b\u5f8c\uff0c\u6211\u8d70\u5f97\u66f4\u52e4\uff0c\u4ee5\u524d\u4e00\u500b\u79ae\u62dc\u53ea\u662f\u5468\u672b\u8d70\u8d70\uff0c\u5f8c\u4f86\u8b8a\u6210\u6bcf\u5929\u90fd\u5f97\u8d70\uff0c\u6bcf\u6b21\u81f3\u5c11\u5f97\u8d70\u4e8c\u5c0f\u6642\uff0c\u6e05\u6668\u6216\u508d\u665a\uff0c\u6108\u8d70\u6108\u6709\u52c1\uff0c\u4e5f\u4e0d\u6703\u9867\u616e\u662f\u5426\u5f71\u97ff\u4e0a\u73ed\u6216\u6703\u592a\u7d2f\uff0c\u4e8b\u5be6\u4e0a\u662f\u6108\u8d70\u6108\u6709\u7cbe\u795e\uff0c\u6108\u5e73\u975c\u3002<\/p>\n<p>\u9019\u4e00\u5e74\u591a\u7684\u8d70\u8def\uff0c\u6211\u4e5f\u611f\u53d7\u5230\u4e00\u4e9b\u8f49\u8b8a\u3002\u8a18\u5f97\u4ee5\u524d\u5728\u8d70\u8def\u904b\u52d5\u6642\uff0c\u8166\u7b4b\u7e3d\u662f\u5728\u76e4\u7b97\u8457\u5176\u4ed6\u4e8b\u60c5\uff0c\u6709\u5f88\u591a\u7684\u60f3\u6cd5\u5ff5\u982d\uff0c\u4e0d\u662f\u60f3\u5230\u4e8b\u696d\u8981\u600e\u9ebc\u885d\u523a\uff0c\u600e\u9ebc\u70ba\u540d\u3001\u70ba\u5229\uff0c\u5c31\u662f\u5bb6\u88cf\u7684\u5404\u7a2e\u7e41\u96dc\u7463\u4e8b\uff0c\u5728\u9019\u7a2e\u72c0\u6cc1\u4e0b\u5b8c\u5168\u5fd8\u8a18\u81ea\u5df1\uff0c\u4e5f\u4e0d\u6703\u53bb\u6ce8\u610f\u81ea\u5df1\u8eab\u9ad4\u7684\u4efb\u4f55\u611f\u89ba\u3002<\/p>\n<p>\u5e36\u8457\u89ba\u77e5\u7684\u60c5\u5f62\u4e0b\u8d70\u8def\uff0c\u96d6\u7136\u6709\u5ff5\u982d\u7522\u751f\uff0c\u6211\u6703\u77e5\u9053\u628a\u6ce8\u610f\u529b\u5e36\u5230\u8173\u5e95\uff0c\u90a3\u500b\u5ff5\u982d\u5f88\u81ea\u7136\u5c31\u4e0d\u898b\u4e86\u3002\u5982\u6b64\u9019\u6a23\u4e00\u6b65\u4e00\u6b65\u6e05\u695a\u7684\u8d70\u8457\uff0c\u601d\u7dd2\u96d6\u4ecd\u6703\u5347\u8d77\uff0c\u4f46\u5b83\u662f\u77ac\u9593\u5373\u904e\uff0c\u7121\u6240\u4f4f\u3002\u5230\u5f8c\u4f86\u81ea\u5df1\u6703\u89ba\u5f97\u597d\u4e45\u90fd\u6c92\u6709\u5176\u4ed6\u5ff5\u982d\u7522\u751f\uff0c\u53ea\u5269\u5168\u8eab\u7d30\u80de\u611f\u89ba\u6574\u500b\u5927\u81ea\u7136\uff0c\u751a\u81f3\u6709\u4e00\u6bb5\u6642\u9593\u6211\u53ea\u8981\u4e00\u6709\u96dc\u5ff5\u7522\u751f\uff0c\u809a\u5b50\u5c31\u4e0d\u8212\u670d\uff0c\u90a3\u81ea\u52d5\u63d0\u9192\u6211\u5e36\u56de\u81ea\u5df1\u8eab\u9ad4\uff0c\u5c31\u5728\u9019\u5e36\u56de\u7684\u524e\u90a3\uff0c\u809a\u5b50\u75bc\u75db\u5168\u6d88\u4e86\u3002\u66f4\u6709\u4e00\u6b21\u8d70\u8457\u8d70\u8457\uff0c\u89ba\u5f97\u81ea\u5df1\u548c\u6574\u500b\u5927\u5730\u6eb6\u5408\u5728\u4e00\u8d77\uff0c\u8207\u82b1\u8349\u6a39\u6728\u98db\u9ce5\u5171\u821e\uff0c\u5168\u8eab\u76ae\u819a\u6bdb\u5b54\u958b\u653e\u548c\u5927\u6c23\u4ea4\u63db\u8457\uff0c\u597d\u50cf\u98c4\u6d6e\u5728\u865b\u7a7a\u4e4b\u4e2d\uff0c\u6211\u5b8c\u5168\u4e0d\u5b58\u5728\u4e86\u3002<\/p>\n<p>\u540c\u6642\u9019\u7a2e\u8d70\u8def\u7684\u611f\u89ba\u4e5f\u878d\u5165\u6211\u7684\u751f\u6d3b\u8207\u5de5\u4f5c\u4e4b\u4e2d\u3002\u7576\u7169\u60f1\uff0c\u4e0d\u5b89\u6607\u8d77\u6642\uff0c\u6211\u6703\u81ea\u767c\u6027\u5730\u628a\u89ba\u77e5\u5e36\u5230\u8173\u5e95\uff0c\u81ea\u7136\u5730\u8eab\u9ad4\u611f\u89ba\u8207\u601d\u7dd2\u8b8a\u5f97\u8f03\u70ba\u5e73\u975c\uff0c\u4e0d\u6703\u88ab\u90a3\u4e9b\u9020\u6210\u6211\u4e0d\u5b89\u7684\u5916\u754c\u5e36\u8d70\uff0c\u5fc3\u88e1\u4e5f\u6f38\u6f38\u7522\u751f\u4e00\u80a1\u5b89\u5b9a\u7684\u529b\u91cf\uff0c\u4e0d\u53d7\u60c5\u7dd2\u8207\u81ea\u6211\u7684\u5de6\u53f3\u3002<\/p>\n<p>\u8d70\u8def\u7adf\u7136\u6709\u9019\u9ebc\u5947\u5999\u7684\u6548\u679c\uff0c\u6211\u66fe\u5617\u8a66\u5f9e\u4e00\u500b\u91ab\u5b78\u7684\u89d2\u5ea6\u53bb\u7406\u89e3\u5b83\uff0c\u96d9\u8173\u662f\u627f\u53d7\u6574\u500b\u8eab\u9ad4\u7684\u57fa\u790e\uff0c\u5b83\u5011\u611f\u53d7\u5230\u6574\u500b\u8eab\u9ad4\u7684\u611f\u89ba\u8207\u904b\u52d5\u795e\u7d93\u6a1e\u7d10\uff0c\u800c\u5927\u8166\u7684\u4e8c\u5927\u8449\uff0c\u6b63\u4e2d\u9802\u8449\u4e3b\u7ba1\u77e5\u89ba\uff0c\u524d\u8449\u4e3b\u7ba1\u904b\u52d5\u63a7\u5236\uff0c\u6b63\u597d\u5c0d\u61c9\u6211\u5011\u7684\u96d9\u8173\uff0c\u6240\u4ee5\u7576\u4f60\u628a\u5169\u8173\u770b\u597d\uff0c\u4f60\u7684\u982d\u8166\u5c31\u88ab\u964d\u670d\uff0c\u7576\u4f60\u597d\u597d\u5e36\u8457\u89ba\u77e5\u8d70\u8def\u6642\uff0c\u982d\u8166\u88ab\u770b\u4f4f\uff0c\u6240\u6709\u8166\u7b4b\u7684\u4f5c\u7528\uff0c\u5fc3\u8b58\u7684\u7522\u751f\uff0c\u7576\u4e0b\u5c31\u6e05\u660e\uff0c\u5167\u5fc3\u7684\u50b7\u5bb3\u4e5f\u5c31\u81ea\u52d5\u6d88\u5931\uff0c\u6240\u6709\u7169\u60f1\u75db\u82e6\u4e5f\u5c31\u4e0d\u5b58\u5728\u4e86\u3002\u9019\u500b\u8ab0\u90fd\u77e5\u9053\u4e5f\u90fd\u6703\u7684\u8d70\u8def\uff0c\u860a\u85cf\u8457\u7121\u9650\u795e\u6a5f\u5999\u7528\u3002\u9019\u500b\u5927\u5bb6\u90fd\u89ba\u5f97\u7c21\u55ae\u53c8\u81ea\u7136\u7684\u8d70\u8def\uff0c\u7adf\u7136\u6709\u9019\u9ebc\u6df1\u7684\u79d8\u5bc6\u3002<\/p>\n<p>\u5f88\u5e78\u904b\u5730\uff0c\u6211\u5011\u6709\u9019\u9ebc\u4e00\u4f4d\u826f\u5e2b\u51fa\u73fe\uff0c\u5f15\u5c0e\u6211\u5011\uff0c\u770b\u8457\u6211\u5011\uff0c\u505a\u4e00\u4ef6\u5f88\u5e73\u51e1\u537b\u53c8\u6709\u5f88\u6df1\u523b\u610f\u7fa9\u7684\u4e8b\u60c5\uff0c\u6211\u5fc3\u5b58\u611f\u6fc0\uff0c\u6df1\u4fe1\u53ea\u8981\u8173\u8e0f\u5be6\u5730\uff0c\u5fc3\u4e2d\u7121\u6c42\u7121\u5f97\uff0c\u5f88\u81ea\u7136\u7684\u4e00\u6b65\u4e00\u6b65\u5730\u8d70\u8457\u9019\u689d\u6709\u89ba\u77e5\u7684\u4fee\u884c\u4e4b\u8def\uff0c\u5c31\u662f\u8d70\u4e0a\u6210\u4f5b\u4e4b\u9053\u3002<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u9019\u7a2e\u8d70\u8def\u7684\u611f\u89ba\u4e5f\u878d\u5165\u6211\u7684\u751f\u6d3b\u8207\u5de5\u4f5c\u4e4b\u4e2d\u3002\u7576\u7169\u60f1\uff0c\u4e0d\u5b89\u6607\u8d77\u6642\uff0c\u6211\u6703\u81ea\u767c\u6027\u5730\u628a\u89ba\u77e5\u5e36\u5230\u8173\u5e95\uff0c\u81ea\u7136\u5730\u8eab\u9ad4\u611f\u89ba\u8207\u601d\u7dd2\u8b8a\u5f97\u8f03\u70ba\u5e73\u975c\uff0c\u4e0d\u6703\u88ab\u90a3\u4e9b\u9020\u6210\u6211\u4e0d\u5b89\u7684\u5916\u754c\u5e36\u8d70\uff0c\u5fc3\u88e1\u4e5f\u6f38\u6f38\u7522\u751f\u4e00\u80a1\u5b89\u5b9a\u7684\u529b\u91cf\uff0c\u4e0d\u53d7\u60c5\u7dd2\u8207\u81ea\u6211\u7684\u5de6\u53f3\u3002<\/p>\n","protected":false},"author":1,"featured_media":0,"comment_status":"closed","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ngg_post_thumbnail":0,"_links_to":"","_links_to_target":""},"categories":[14],"tags":[],"_links":{"self":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/179"}],"collection":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/comments?post=179"}],"version-history":[{"count":4,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/179\/revisions"}],"predecessor-version":[{"id":183,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/179\/revisions\/183"}],"wp:attachment":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/media?parent=179"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/categories?post=179"},{"taxonomy":"post_tag","embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/tags?post=179"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}