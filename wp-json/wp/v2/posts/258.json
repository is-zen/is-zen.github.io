{"id":258,"date":"2005-06-21T21:12:04","date_gmt":"2005-06-22T03:12:04","guid":{"rendered":"http:\/\/www.is-zen.org\/tc\/?p=258"},"modified":"2010-02-23T21:15:54","modified_gmt":"2010-02-24T03:15:54","slug":"myhome","status":"publish","type":"post","link":"http:\/\/www.is-zen.org\/tc\/2005\/myhome\/","title":{"rendered":"\u627e\u5230\u81ea\u5df1\u7684\u5bb6"},"content":{"rendered":"<p>\u4f5c\u8005\uff1a\u9cf3\u73e0<\/p>\n<p>\u4e16\u9593\u7684\u7121\u5e38\u771f\u4e0d\u662f\u7528\u982d\u8166\u53ef\u4ee5\u8a08\u756b\u7684\u3002\u56e0\u8457\u9019\u6b21\u7684\u56e0\u7de3\uff0c\u770b\u8457\u81ea\u5df1\u7684\u5fc3\uff0c\u4f3c\u4e4e\u8d77\u4f0f\u4e26\u4e0d\u5927\uff0c\u9a5a\u8a1d\u8457\u8d70\u8def\u8b93\u81ea\u5df1\u9762\u5c0d\u8457\u56e0\u7de3\u7684\u8b8a\u5316\uff0c\u5fc3\u4e2d\u7684\u9a5a\u614c\u6e1b\u5c11\u4e86\u3002\u5fc3\u5be7\u975c\uff0c\u4e0d\u5bb3\u6015\uff0c\u4e0d\u671f\u5f85\uff0c\u770b\u8457\u6240\u6709\u7684\u767c\u751f\uff0c\u9762\u5c0d\u8655\u7406\uff0c\u66f4\u7cbe\u9032\u7684\u8d70\u8def\u3002<\/p>\n<p>\u900f\u904e\u8d70\u8def\uff0c\u611f\u89ba\u80fd\u91cf\u7684\u589e\u5f37\u3002\u524d\u4e9b\u5929\u4e0a\u5c71\u8d70\u8def\uff0c\u5728\u5c71\u4e0a\u8d70\u5f97\u8173\u9178\uff0c\u505c\u4e0b\u4f86\u4f11\u606f\u6642\uff0c\u5fc3\u4e2d\u60f3\u5b78\u7fd2\u7ad9\u6a01\uff0c\u65bc\u662f\u96d9\u8173\u5fae\u5f4e\uff0c\u5fc3\u60f3\u7b2c\u4e00\u6b21\u505a\u5c31\u5148\u7ad910\u5206\u9418\u3002\u96a8\u8457\u6642\u9593\u7684\u904e\u53bb\uff0c\u767c\u73fe\u8eab\u9ad4\u5728\u81ea\u52d5\u7684\u8abf\u6574\u59ff\u52e2\uff0c\u81c0\u90e8\u7531\u524d\u5f80\u5f8c\u7684\u6536\u7e2e\uff0c\u6162\u6162\u7684\u89ba\u5f97\u8173\u9178\u3002\u6211\u7ad9\u8d77\u4f86\u7e7c\u7e8c\u8d70\u4e00\u5c0f\u6bb5\u5f8c\u505c\u4e0b\u4f86\uff0c\u9019\u6642\u767c\u73fe\u6d77\u5e95\u8f2a\u4e0a\u4e0b\u7684\u6536\u7e2e\u4e00\u9663\u4e4b\u5f8c\u5c31\u505c\u4e0b\u4f86\u3002\u53c8\u6709\u4e00\u6b21\u5728\u5bb6\u4e2d\u7e5e\u5708\u8d70\u8def\uff0c\u5ffd\u7136\u89ba\u5f97\u5730\u9762\u6d6e\u8d77\uff0c\u6709\u4e00\u80a1\u6c23\u6d41\u5f80\u96d9\u8173\u5230\u8173\u5e95\u3002\u8d70\u8457\u8d70\u8457\uff0c\u611f\u89ba\u5169\u96bb\u8173\u5f9e\u5de6\u8173\u7684\u8173\u8ddf\u5230\u8173\u638c\u5230\u8173\u5c16\uff0c\u8173\u5c16\u8e2e\u8d77\uff0c\u7136\u5f8c\u53f3\u8173\u7684\u8173\u8ddf\u8e0f\u5730\uff0c\u6574\u500b\u8173\u638c\u8457\u5730\u5f8c\u8173\u5c16\u8e2e\u8d77\u3002\u611f\u89ba\u96d9\u8173\u4f3c\u4e4e\u4e0d\u8cbb\u529b\u6c23\u7684\u5728\u8d70\u8457\uff0c\u6709\u9ede\u50cf\u5212\u8239\u7684\u611f\u89ba\u3002\u5c31\u9019\u6a23\u8d70\u4e86\u597d\u5e7e\u5708\uff0c\u5fc3\u4e2d\u60f3\u9019\u61c9\u8a72\u662f\u822c\u821f\u4e09\u771b\uff0c\u5fc3\u60f3\u9019\u4e5f\u6c92\u4ec0\u9ebc\uff0c\u56e0\u70ba\u5e2b\u7236\u8aaa\u7121\u6240\u5f97\uff0c\u7121\u6240\u6c42\u3002\u770b\u8457\u770b\u8457\uff0c\u89ba\u5f97\u6c92\u4ec0\u9ebc\u610f\u601d\u5c31\u505c\u4e0b\u4f86\u4e86\u3002<\/p>\n<p>\u9762\u5c0d\u57fa\u5730\u53f0\u767c\u5c04\u96fb\u6ce2\uff0c\u8f3b\u5c04\u96fb\u6ce2\u767c\u5c04\u6642\u8179\u90e8\u611f\u89ba\u4e00\u9663\u7684\u75bc\u75db\uff0c\u8178\u80c3\u56e0\u96fb\u78c1\u6ce2\u800c\u8815\u52d5\uff0c\u5f8c\u8166\u53f3\u90e8\u75bc\u75db\u4e5f\u63a5\u6536\u4f86\u81ea\u5f8c\u65b9\u57fa\u5730\u53f0\u7684\u767c\u5c04\u96fb\u6ce2\u3002\u9019\u500b\u96fb\u6ce2\u7684\u5f37\u5ea6\u8a2d\u5b9a\u5728 -60dBm\uff0c\u56e0\u70ba\u4e00\u76f4\u6301\u7e8c\u7684\u9032\u884c\u6e2c\u8a66\uff0c\u96fb\u78c1\u6ce2\u4f3c\u4e4e\u64f4\u6563\u5728\u6574\u500b\u5468\u570d\uff0c\u4ee4\u4eba\u53cd\u61c9\u9072\u7de9\uff0c\u982d\u90e8\u4e5f\u611f\u89ba\u660f\u6c88\uff0c\u773c\u775b\u5f88\u9178\u3002\u53ef\u80fd\u56e0\u70ba\u9019\u500b\u539f\u56e0\uff0c\u6574\u500b\u4eba\u986f\u5f97\u75b2\u52de\uff0c\u4e0d\u60f3\u5de5\u4f5c\uff0c\u4e0d\u60f3\u601d\u8003\u3002<\/p>\n<p>\u8d70\u8def\u6642\u770b\u5230\u5ff5\u982d\u6c92\u6709\u4e2d\u65b7\uff0c\u800c\u89c0\u7167\u4e5f\u6301\u7e8c\u8457\uff0c\u5c31\u9019\u9ebc\u7684\u540c\u6642\u56de\u5230\u8173\u5e95\uff0c\u4e5f\u540c\u6642\u770b\u5230\u5ff5\u982d\u3002\u4e00\u4e0d\u5c0f\u5fc3\u96a8\u8457\u5ff5\u982d\u7d1b\u98db\uff0c\u770b\u5230\u6642\u518d\u56de\u4f86\u3002\u56de\u4f86\u7684\u7576\u4e0b\u624d\u767c\u73fe\u8173\u7684\u53ef\u8cb4\uff0c\u5ffd\u7136\u89ba\u5f97\u5e78\u8667\u9084\u6709\u8173\u53ef\u4ee5\u4f9d\u9760\uff0c\u5426\u5247\u9019\u4e00\u88ab\u5e36\u8d70\u53c8\u6389\u5165\u601d\u7dd2\u4e2d\u3002\u7576\u6301\u7e8c\u89c0\u7167\u6642\u767c\u73fe\u6839\u672c\u5c31\u7121\u6687\u53bb\u7ba1\u5ff5\u982d\u4e86\uff0c\u4efb\u7531\u5ff5\u982d\u672c\u8eab\u5347\u8d77\u53c8\u843d\u4e0b\uff0c\u800c\u89c0\u7167\u6301\u7e8c\u8457\u3002\u7d93\u6b77\u4e86\u9019\u500b\u6b77\u7a0b\uff0c\u5c0d\u65bc\u89c0\u7167\u6709\u4e86\u4e0d\u540c\u7684\u89ba\u53d7\u3002<\/p>\n<p>\u7576\u8d70\u8def\u6642\uff0c\u8f15\u9b06\u7684\u8d70\u8457\uff0c\u4e5f\u4e0d\u8457\u529b\u5728\u8173\u5e95\uff0c\u8f15\u9b06\u7684\u77e5\u9053\u81ea\u5df1\u5728\u8d70\u8def\uff0c\u6162\u6162\u7684\u5347\u8d77\u4e86\u5be7\u975c\u7684\u611f\u89ba\u3002\u9019\u6642\u6c92\u6709\u5411\u5916\u6c42\uff0c\u4e5f\u6c92\u6709\u5411\u5167\u6c42\uff0c\u597d\u50cf\u6c92\u6709\u4e86\u5167\u5916\u7684\u754c\u7dda\u3002\u9019\u8f15\u9b06\u5be7\u975c\uff0c\u4e0d\u5728\u5167\u4e5f\u4e0d\u5728\u5916\uff0c\u662f\u4e00\u500b\u6574\u9ad4\u7684\u3002\u4f3c\u4e4e\u5168\u8eab\u7684\u7d30\u80de\u90fd\u662f\u8f15\u9b06\u5be7\u975c\u7684\uff0c\u9019\u6642\u6709\u7a2e\u8ddf\u81ea\u5df1\u5728\u4e00\u8d77\u7684\u611f\u89ba\u3002\u6b64\u8655\u5c31\u662f\u5b89\u5fc3\u8655\uff0c\u5167\u5fc3\u5c31\u662f\u6de8\u571f\uff0c\u4e09\u5343\u5927\u5343\u4e16\u754c\u90fd\u5728\u6211\u7684\u5167\u5fc3\u3002\u96e3\u602a\u5ee3\u6b3d\u8001\u548c\u5c1a\u8981\u5713\u5bc2\u6642\u8aaa\uff1a\u300c\u7121\u4f86\u4e5f\u7121\u53bb\uff0c\u7121\u4e8b\u60c5\u3002\u300d\u5fb9\u8056\u4e0a\u5e2b\u8aaa\uff1a\u300c\u81ea\u5df1\u5c31\u662f\u5b89\u5fc3\u8655\u3002\u300d\u6211\u627e\u5230\u81ea\u5df1\u7684\u5bb6\u4e86\u3002<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u8d70\u8def\u6642\u770b\u5230\u5ff5\u982d\u6c92\u6709\u4e2d\u65b7\uff0c\u800c\u89c0\u7167\u4e5f\u6301\u7e8c\u8457\uff0c\u5c31\u9019\u9ebc\u7684\u540c\u6642\u56de\u5230\u8173\u5e95\uff0c\u4e5f\u540c\u6642\u770b\u5230\u5ff5\u982d\u3002\u4e00\u4e0d\u5c0f\u5fc3\u96a8\u8457\u5ff5\u982d\u7d1b\u98db\uff0c\u770b\u5230\u6642\u518d\u56de\u4f86\u3002\u56de\u4f86\u7684\u7576\u4e0b\u624d\u767c\u73fe\u8173\u7684\u53ef\u8cb4\uff0c\u5ffd\u7136\u89ba\u5f97\u5e78\u8667\u9084\u6709\u8173\u53ef\u4ee5\u4f9d\u9760\uff0c\u5426\u5247\u9019\u4e00\u88ab\u5e36\u8d70\u53c8\u6389\u5165\u601d\u7dd2\u4e2d\u3002<\/p>\n","protected":false},"author":1,"featured_media":0,"comment_status":"closed","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ngg_post_thumbnail":0,"_links_to":"","_links_to_target":""},"categories":[15],"tags":[],"_links":{"self":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/258"}],"collection":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/comments?post=258"}],"version-history":[{"count":2,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/258\/revisions"}],"predecessor-version":[{"id":260,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/258\/revisions\/260"}],"wp:attachment":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/media?parent=258"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/categories?post=258"},{"taxonomy":"post_tag","embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/tags?post=258"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}