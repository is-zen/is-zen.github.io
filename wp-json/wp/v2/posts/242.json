{"id":242,"date":"2005-06-19T20:34:02","date_gmt":"2005-06-20T02:34:02","guid":{"rendered":"http:\/\/www.is-zen.org\/tc\/?p=242"},"modified":"2010-02-23T20:40:35","modified_gmt":"2010-02-24T02:40:35","slug":"thesecret","status":"publish","type":"post","link":"http:\/\/www.is-zen.org\/tc\/2005\/thesecret\/","title":{"rendered":"\u8d70\u8def\u6709\u79d8\u5bc6\u55ce\uff1f\u5b83\u662f\u79d8\u65b9"},"content":{"rendered":"<p>\u4f5c\u8005\uff1a\u5927\u60e0<\/p>\n<p>\u5f9e\u5c0f\u5c31\u559c\u6b61\u9a0e\u8173\u8e0f\u8eca\u548c\u8d70\u8def\uff0c\u7e3d\u4ee5\u6b64\u5169\u7a2e\u65b9\u5f0f\u4f86\u5230\u9054\u76ee\u7684\u5730\u3002\u4ee5\u611f\u89ba\u4f86\u8aaa\uff0c\u9a0e\u8173\u8e0f\u8eca\u597d\u50cf\u5f80\u5929\u4e0a\u98db\uff0c\u8d70\u8def\u5247\u50cf\u5f80\u5730\u4e0b\u6df1\u5165\u3002\u4ee5\u6bd4\u55bb\u4f86\u8aaa\uff0c\u9a0e\u8173\u8e0f\u8eca\u662f\u6211\u7684\u5922\u60f3\uff0c\u8d70\u8def\u662f\u6211\u7684\u7406\u60f3\u3002\u4ee5\u5fae\u5999\u4f86\u8aaa\uff0c\u9a0e\u8173\u8e0f\u8eca\u53ef\u4ee5\u5713\u6211\u5916\u5728\u7684\u5922\uff0c\u8d70\u8def\u53ef\u4ee5\u5713\u6211\u5167\u5728\u7684\u5fc3\u3002<\/p>\n<p>\u5e74\u7d00\u6f38\u9577\uff0c\u8a62\u554f\u91ab\u751f\uff0c\u4ec0\u9ebc\u6a23\u7684\u904b\u52d5\u5c0d\u8eab\u9ad4\u6700\u597d\uff0c\u6700\u9069\u5408\u6211\u73fe\u5728\u7684\u5e74\u9f61\u3002\u91ab\u751f\u8aaa\u8d70\u8def\u5c31\u662f\u6700\u597d\u7684\u904b\u52d5\u4e86\uff0c\u4e00\u661f\u671f\u81f3\u5c11\u8d70\u4e09\uff0c\u56db\u6b21\uff0c(\u7576\u7136\u6700\u597d\u662f\u6bcf\u5929)\u6bcf\u6b21\u56db\u5341\u5206\u9418\u5230\u4e00\u500b\u6216\u4e00\u500b\u534a\u5c0f\u6642\u3002\u5de7\u9047\u6bdb\u8001\u5e2b\uff0c\u4e5f\u9f13\u52f5\u8d70\u8def\u3002\u55dc\u597d\u52a0\u4e0a\u4e8c\u5e2b(\u8001\u5e2b\uff0c\u91ab\u5e2b)\u7684\u8033\u63d0\u9762\u547d\uff0c\u65bc\u662f\u5c31\u958b\u6b65\u8d70\u56c9\ufe57<\/p>\n<p>\u6211\u525b\u958b\u59cb\u8d70\u8def\u6642\uff0c\u4efb\u610f\u7684\u60f3\u81ea\u5df1\u60f3\u8981\u60f3\u7684\u4e8b\uff0c\u8a8d\u771f\u7684\u60f3\uff0c\u5fb9\u5e95\u7684\u60f3\u3002\u4e5f\u53ef\u4ee5\u4ec0\u9ebc\u90fd\u4e0d\u60f3\uff0c\u8b93\u5927\u8166\u7a7a\u7a7a\uff0c\u8f15\u8f15\u9b06\u9b06\uff0c\u60a0\u7136\u81ea\u5f97\u3002<\/p>\n<p>\u5728\u7e7c\u7e8c\u7684\u8d70\u8def\u4e2d\uff0c\u6211\u767c\u73fe\u8d70\u8def\u80fd\u8b93\u4eba\u654f\u92b3\u5730\u77e5\u9053\u81ea\u5df1\u7684\u8eab\u9ad4\u7684\u5404\u500b\u90e8\u4f4d\uff0c\u4f55\u8655\u6709\u75c5\u75db\uff0c\u4f55\u8655\u6709\u7f3a\u9677\u3002<\/p>\n<p>\u5728\u6df1\u5165\u7684\u8d70\u8def\u4e2d\uff0c\u6211\u9ad4\u9a57\u5230\u8d70\u8def\u80fd\u8b93\u4eba\u52c7\u6562\u7684\u9762\u5c0d\u4e8b\u5be6(\u4eba\u3001\u4e8b\u3001\u7269)\uff0c\u52c7\u6562\u7684\u5927\u7b11\u81ea\u5df1\u7684\u8caa\u778b\u75f4\u3002\u52c7\u6562\u7684\u8d70\u51fa\u75db\u5fb9\u4eba\u5fc3\u7684\u82e6\u3001\u96e3\u3001\u611b\u3001\u6068\u3001\u60c5\u3001\u4ec7\u3002\u8d70\u8457\u8d70\u8457\uff0c\u300c\u5fc3\u300d\u65e2\u6de8\u53c8\u6e05\u4e14\u660e\u3002<\/p>\n<p>\u65bc\u81ea\u5728\u7684\u8d70\u8def\u4e2d\uff0c\u6211\u9ad4\u609f\u4e86\u89c0\u81ea\u5728\u83e9\u85a9\uff0c\u7167\u898b\u4e94\u860a\u7686\u7a7a\u7684\u79d8\u5bc6\uff0c\u90a3\u5c31\u662f\uff1a\u8d70\u8def\u8d70\u8def\uff0c\u4e00\u76f4\u8d70\u8def\u3002\u89c0\u5bdf\u89c0\u5bdf\uff0c\u518d\u89c0\u5bdf\u3002\u89c0\u7167\u89c0\u7167\uff0c\u5ff5\u5ff5\u89c0\u7167\uff0c\u5ff5\u5ff5\u524e\u90a3\u76f8\u61c9\u3002\u4ee5\u6b64\u5c64\u5c64\u660e\u4e86\u7121\u4e0a\u751a\u6df1\u5fae\u5999\u6cd5\u3002<\/p>\n<p>\u4eba\u4e4b\u4e00\u751f\uff0c\u8ab0\u80fd\u7121\u61be\u3002\u5de7\u9047\u6bdb\u8001\u5e2b\uff0c\u6b64\u751f\u7121\u61be\u3002\u8b39\u9075\u6559\u8aa8\uff0c\u8b39\u6b64\u7533\u8b1d\u3002<\/p>\n<p>\u6211\u5df2\u6df1\u4fe1\uff0c\u7d93\u7531\u8d70\u8def\u53ef\u4ee5\u65bc\u6b64\u751f\u4e2d\u660e\u4e86\u6b64\u5fc3\uff0c\u5f97\u898b\u81ea\u5df1\u771f\u5982\u672c\u6027\u3002<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u5728\u7e7c\u7e8c\u7684\u8d70\u8def\u4e2d\uff0c\u6211\u767c\u73fe\u8d70\u8def\u80fd\u8b93\u4eba\u654f\u92b3\u5730\u77e5\u9053\u81ea\u5df1\u7684\u8eab\u9ad4\u7684\u5404\u500b\u90e8\u4f4d\uff0c\u4f55\u8655\u6709\u75c5\u75db\uff0c\u4f55\u8655\u6709\u7f3a\u9677\u3002\u5728\u6df1\u5165\u7684\u8d70\u8def\u4e2d\uff0c\u6211\u9ad4\u9a57\u5230\u8d70\u8def\u80fd\u8b93\u4eba\u52c7\u6562\u7684\u9762\u5c0d\u4e8b\u5be6(\u4eba\u3001\u4e8b\u3001\u7269)\uff0c\u52c7\u6562\u7684\u5927\u7b11\u81ea\u5df1\u7684\u8caa\u778b\u75f4\u3002\u52c7\u6562\u7684\u8d70\u51fa\u75db\u5fb9\u4eba\u5fc3\u7684\u82e6\u3001\u96e3\u3001\u611b\u3001\u6068\u3001\u60c5\u3001\u4ec7\u3002\u8d70\u8457\u8d70\u8457\uff0c\u300c\u5fc3\u300d\u65e2\u6de8\u53c8\u6e05\u4e14\u660e\u3002<\/p>\n","protected":false},"author":1,"featured_media":0,"comment_status":"closed","ping_status":"open","sticky":false,"template":"","format":"standard","meta":{"ngg_post_thumbnail":0,"_links_to":"","_links_to_target":""},"categories":[15],"tags":[],"_links":{"self":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/242"}],"collection":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts"}],"about":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/types\/post"}],"author":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/comments?post=242"}],"version-history":[{"count":2,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/242\/revisions"}],"predecessor-version":[{"id":247,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/posts\/242\/revisions\/247"}],"wp:attachment":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/media?parent=242"}],"wp:term":[{"taxonomy":"category","embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/categories?post=242"},{"taxonomy":"post_tag","embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/tags?post=242"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}