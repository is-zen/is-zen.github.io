{"id":508,"date":"2011-08-24T10:35:25","date_gmt":"2011-08-24T16:35:25","guid":{"rendered":"http:\/\/www.is-zen.org\/tc\/?page_id=508"},"modified":"2011-08-24T15:06:43","modified_gmt":"2011-08-24T21:06:43","slug":"jdxj001_xinjing","status":"publish","type":"page","link":"http:\/\/www.is-zen.org\/tc\/sutracollection\/jdxj001_xinjing\/","title":{"rendered":"\u822c\u82e5\u6ce2\u7f85\u871c\u591a\u5fc3\u7d93"},"content":{"rendered":"<p>\u5510 \u4e09\u85cf\u6cd5\u5e2b \u7384\u5958 \u8b6f<\/p>\n<p>\u89c0\u81ea\u5728\u83e9\u85a9\u3002\u884c\u6df1\u822c\u82e5\u6ce2\u7f85\u871c\u591a\u6642\u3002\u7167\u898b\u4e94\u860a\u7686\u7a7a\u3002\u5ea6\u4e00\u5207\u82e6\u5384\u3002<br \/>\n\u820d\u5229\u5b50\u3002\u8272\u4e0d\u7570\u7a7a\u3002\u7a7a\u4e0d\u7570\u8272\u3002\u8272\u5373\u662f\u7a7a\u3002\u7a7a\u5373\u662f\u8272\u3002\u53d7\u60f3\u884c\u8b58\u3002\u4ea6\u5fa9\u5982\u662f\u3002<\/p>\n<p>\u820d\u5229\u5b50\u3002\u662f\u8af8\u6cd5\u7a7a\u76f8\u3002\u4e0d\u751f\u4e0d\u6ec5\u3002\u4e0d\u57a2\u4e0d\u6de8\u3002\u4e0d\u589e\u4e0d\u6e1b\u3002<br \/>\n\u662f\u6545\u7a7a\u4e2d\u7121\u8272\u3002\u7121\u53d7\u60f3\u884c\u8b58\u3002\u7121\u773c\u8033\u9f3b\u820c\u8eab\u610f\u3002\u7121\u8272\u8072\u9999\u5473\u89f8\u6cd5\u3002<br \/>\n\u7121\u773c\u754c\u3002\u4e43\u81f3\u7121\u610f\u8b58\u754c\u3002\u7121\u7121\u660e\u3002\u4ea6\u7121\u7121\u660e\u76e1\u3002\u4e43\u81f3\u7121\u8001\u6b7b\u3002\u4ea6\u7121\u8001\u6b7b\u76e1\u3002<\/p>\n<p>\u7121\u82e6\u96c6\u6ec5\u9053\u3002\u7121\u667a\u4ea6\u7121\u5f97\u3002\u4ee5\u7121\u6240\u5f97\u6545\u3002\u83e9\u63d0\u85a9\u57f5\u3002<br \/>\n\u4f9d\u822c\u82e5\u6ce2\u7f85\u871c\u591a\u6545\u3002\u5fc3\u7121\u7f63\u7919\u3002<br \/>\n\u7121\u7f63\u7919\u6545\u3002\u7121\u6709\u6050\u6016\u3002\u9060\u96e2\u985b\u5012\u5922\u60f3\u3002\u7a76\u7adf\u6d85\u69c3\u3002<\/p>\n<p>\u4e09\u4e16\u8af8\u4f5b\u3002\u4f9d\u822c\u82e5\u6ce2\u7f85\u871c\u591a\u6545\u3002\u5f97\u963f\u8028\u591a\u7f85\u4e09\u85d0\u4e09\u83e9\u63d0\u3002<br \/>\n\u6545\u77e5\u822c\u82e5\u6ce2\u7f85\u871c\u591a\u3002\u662f\u5927\u795e\u546a\u3002\u662f\u5927\u660e\u546a\u3002\u662f\u7121\u4e0a\u546a\u3002\u662f\u7121\u7b49\u7b49\u546a\u3002<br \/>\n\u80fd\u9664\u4e00\u5207\u82e6\u3002\u771f\u5be6\u4e0d\u865b\u3002\u6545\u8aaa\u822c\u82e5\u6ce2\u7f85\u871c\u591a\u546a\u3002\u5373\u8aaa\u546a\u66f0<\/p>\n<p>\u63ed\u8ae6\u63ed\u8ae6\u3000\u6ce2\u7f85\u63ed\u8ae6\u3000\u6ce2\u7f85\u50e7\u63ed\u8ae6\u3000\u83e9\u63d0\u85a9\u5a46\u8a36<\/p>\n<p>\u3010\u7d93\u6587\u8cc7\u8a0a\u3011\u4e7e\u9686\u5927\u85cf\u7d93 \u5927\u4e58\u7d93 \u822c\u82e5\u90e8(\u5341\u516d) \u4e00.\u4e00\u516b \u822c\u82e5\u6ce2\u7f85\u871c\u591a\u5fc3\u7d93 \u516d0\u4e94<\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u5510 \u4e09\u85cf\u6cd5\u5e2b \u7384\u5958 \u8b6f \u89c0\u81ea\u5728\u83e9\u85a9\u3002\u884c\u6df1\u822c\u82e5\u6ce2\u7f85\u871c\u591a\u6642\u3002\u7167\u898b\u4e94\u860a\u7686\u7a7a\u3002\u5ea6\u4e00\u5207\u82e6\u5384\u3002 \u820d\u5229\u5b50\u3002\u8272\u4e0d\u7570\u7a7a\u3002\u7a7a\u4e0d\u7570\u8272\u3002\u8272\u5373\u662f\u7a7a\u3002\u7a7a\u5373\u662f\u8272\u3002\u53d7\u60f3\u884c\u8b58\u3002\u4ea6\u5fa9\u5982\u662f\u3002 \u820d\u5229\u5b50\u3002\u662f\u8af8\u6cd5\u7a7a\u76f8\u3002\u4e0d\u751f\u4e0d\u6ec5\u3002\u4e0d\u57a2\u4e0d\u6de8\u3002\u4e0d\u589e\u4e0d\u6e1b\u3002 \u662f\u6545\u7a7a\u4e2d\u7121\u8272\u3002\u7121\u53d7\u60f3\u884c\u8b58\u3002\u7121\u773c\u8033\u9f3b\u820c\u8eab\u610f\u3002\u7121\u8272\u8072\u9999\u5473\u89f8\u6cd5\u3002 \u7121\u773c\u754c\u3002\u4e43\u81f3\u7121\u610f\u8b58\u754c\u3002\u7121\u7121\u660e\u3002\u4ea6\u7121\u7121\u660e\u76e1\u3002\u4e43\u81f3\u7121\u8001\u6b7b\u3002\u4ea6\u7121\u8001\u6b7b\u76e1\u3002 \u7121\u82e6\u96c6\u6ec5\u9053\u3002\u7121\u667a\u4ea6\u7121\u5f97\u3002\u4ee5\u7121\u6240\u5f97\u6545\u3002\u83e9\u63d0\u85a9\u57f5\u3002 \u4f9d\u822c\u82e5\u6ce2\u7f85\u871c\u591a\u6545\u3002\u5fc3\u7121\u7f63\u7919\u3002 \u7121\u7f63\u7919\u6545\u3002\u7121\u6709\u6050\u6016\u3002\u9060\u96e2\u985b\u5012\u5922\u60f3\u3002\u7a76\u7adf\u6d85\u69c3\u3002 \u4e09\u4e16\u8af8\u4f5b\u3002\u4f9d\u822c\u82e5\u6ce2\u7f85\u871c\u591a\u6545\u3002\u5f97\u963f\u8028\u591a\u7f85\u4e09\u85d0\u4e09\u83e9\u63d0\u3002 \u6545\u77e5\u822c\u82e5\u6ce2\u7f85\u871c\u591a\u3002\u662f\u5927\u795e\u546a\u3002\u662f\u5927\u660e\u546a\u3002\u662f\u7121\u4e0a\u546a\u3002\u662f\u7121\u7b49\u7b49\u546a\u3002 \u80fd\u9664\u4e00\u5207\u82e6\u3002\u771f\u5be6\u4e0d\u865b\u3002\u6545\u8aaa\u822c\u82e5\u6ce2\u7f85\u871c\u591a\u546a\u3002\u5373\u8aaa\u546a\u66f0 \u63ed\u8ae6\u63ed\u8ae6\u3000\u6ce2\u7f85\u63ed\u8ae6\u3000\u6ce2\u7f85\u50e7\u63ed\u8ae6\u3000\u83e9\u63d0\u85a9\u5a46\u8a36 \u3010\u7d93\u6587\u8cc7\u8a0a\u3011\u4e7e\u9686\u5927\u85cf\u7d93 \u5927\u4e58\u7d93 \u822c\u82e5\u90e8(\u5341\u516d) \u4e00.\u4e00\u516b \u822c\u82e5\u6ce2\u7f85\u871c\u591a\u5fc3\u7d93 \u516d0\u4e94<\/p>\n","protected":false},"author":1,"featured_media":0,"parent":122,"menu_order":0,"comment_status":"closed","ping_status":"open","template":"","meta":{"ngg_post_thumbnail":0,"_links_to":"","_links_to_target":""},"_links":{"self":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/pages\/508"}],"collection":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/pages"}],"about":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/types\/page"}],"author":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/users\/1"}],"replies":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/comments?post=508"}],"version-history":[{"count":7,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/pages\/508\/revisions"}],"predecessor-version":[{"id":519,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/pages\/508\/revisions\/519"}],"up":[{"embeddable":true,"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/pages\/122"}],"wp:attachment":[{"href":"http:\/\/www.is-zen.org\/tc\/wp-json\/wp\/v2\/media?parent=508"}],"curies":[{"name":"wp","href":"https:\/\/api.w.org\/{rel}","templated":true}]}}